{
  "name": "agenciachucao-cl",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro check && cross-env ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "check": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro check",
    "lint": "eslint . && stylelint \"src/**/*.css\" --allow-empty-input && npm run test:text",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.css\" --fix --allow-empty-input",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run tests/source-hygiene.spec.ts && playwright test",
    "test:a11y": "playwright test tests/visual/a11y.spec.ts",
    "test:build": "playwright test tests/build-output.spec.ts",
    "test:consent": "playwright test tests/analytics-consent.spec.ts",
    "test:source": "vitest run tests/source-hygiene.spec.ts",
    "test:text": "node scripts/check-text-quality.mjs",
    "test:lighthouse": "lhci autorun"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "astro": "6.4.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.11.3",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@fontsource/lora": "5.2.8",
    "@fontsource/montserrat": "5.2.8",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.60.0",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "cross-env": "10.1.0",
    "eslint": "10.4.0",
    "eslint-plugin-astro": "1.7.0",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "stylelint": "17.12.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
