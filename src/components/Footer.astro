---
const year = new Date().getFullYear();

const services = [
  { label: 'Gestión de Redes Sociales', href: '/servicios/gestion-de-redes-sociales/' },
  { label: 'SEO Técnico',               href: '/servicios/seo-tecnico-y-posicionamiento/' },
  { label: 'Desarrollo Web',            href: '/servicios/desarrollo-web/' },
  { label: 'Google Business Profile',   href: '/servicios/optimizacion-de-google-business-profile/' },
  { label: 'Creación de Contenido',     href: '/servicios/creacion-de-contenido/' },
  { label: 'Email Marketing',           href: '/servicios/email-marketing/' },
];
---

<footer class="footer">
  <div class="container footer-inner">

    <!-- Col 1: brand -->
    <div class="footer-brand">
      <a href="/" class="wordmark" aria-label="Agencia Chucao — inicio">
        <img src="/images/assets/chucao-logo.svg" alt="" aria-hidden="true" class="wordmark-logo" width="28" height="28" />
        <span class="wordmark-name"><span class="wordmark-light">agencia</span><span class="wordmark-bold">chucao</span></span>
      </a>
      <p class="footer-tagline">
        Agencia de marketing digital para negocios que quieren resultados reales. Santiago, Chile.
      </p>
      <div class="footer-soc">
        <a href="https://www.instagram.com/agenciachucao" target="_blank" rel="noopener noreferrer" class="footer-soc-link" aria-label="Agencia Chucao en Instagram">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/agencia-chucao/" target="_blank" rel="noopener noreferrer" class="footer-soc-link" aria-label="Agencia Chucao en LinkedIn">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>

    <!-- Col 2: services -->
    <nav class="footer-nav" aria-label="Servicios">
      <p class="footer-col-label">Servicios</p>
      <ul>
        {services.map(({ label, href }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </nav>

    <!-- Col 3: contact + legal -->
    <div class="footer-contact">
      <p class="footer-col-label">Contacto</p>
      <a href="/contacto/" class="footer-contact-link">Escríbenos →</a>
      <a
        href={`mailto:contacto@agenciachucao.cl`}
        class="footer-email"
      >contacto@agenciachucao.cl</a>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>© {year} Agencia Chucao. Todos los derechos reservados.</p>
      <div class="footer-legal-links">
        <a href="/politica-de-cookies/">Política de cookies</a>
        <button class="cookie-manage-btn" id="cookie-manage-btn">
          Gestionar preferencias de cookies
        </button>
      </div>
    </div>
  </div>
</footer>

<script>
  document.getElementById('cookie-manage-btn')?.addEventListener('click', () => {
    document.cookie = 'chucao_consent=; max-age=0; path=/';
    window.location.reload();
  });
</script>

<style>
  .footer {
    background: var(--color-forest);
    color: rgba(255, 255, 255, 0.65);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-block: 4rem;
  }
  @media (min-width: 768px) {
    .footer-inner {
      grid-template-columns: 1.5fr 1fr 1fr;
      gap: 3rem;
    }
  }

  /* Wordmark */
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .wordmark-logo {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    display: block;
  }
  .wordmark-name { display: inline; }
  .wordmark-light {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 18px;
    color: rgba(255, 255, 255, 0.75);
  }
  .wordmark-bold {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 18px;
    color: var(--color-orange);
  }

  .footer-tagline {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.45);
    max-width: 30ch;
  }

  /* Nav columns */
  .footer-col-label {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 1rem;
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .footer-nav a {
    font-family: var(--font-sans);
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-nav a:hover { color: var(--color-white); }

  /* Contact */
  .footer-contact { display: flex; flex-direction: column; gap: 0.75rem; }
  .footer-contact-link {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 13px;
    color: var(--color-orange);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-contact-link:hover { color: var(--color-white); }
  .footer-email {
    font-family: var(--font-mono);
    font-size: 12px;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    word-break: break-all;
    transition: color 0.15s;
  }
  .footer-email:hover { color: rgba(255, 255, 255, 0.8); }

  /* Social profile links */
  .footer-soc {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }
  .footer-soc-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.07);
    color: rgba(255, 255, 255, 0.5);
    transition: background 0.2s, color 0.2s;
  }
  .footer-soc-link:hover {
    background: rgba(255, 255, 255, 0.14);
    color: var(--color-white);
  }
  .footer-soc-link svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
  }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-block: 1.25rem;
  }
  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .footer-bottom p {
    font-family: var(--font-sans);
    font-size: 11px;
    color: rgba(255, 255, 255, 0.3);
  }
  .footer-legal-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .footer-legal-links a,
  .cookie-manage-btn {
    font-family: var(--font-sans);
    font-size: 11px;
    color: rgba(255, 255, 255, 0.35);
    text-decoration: none;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 0.15s;
  }
  .footer-legal-links a:hover,
  .cookie-manage-btn:hover { color: rgba(255, 255, 255, 0.75); }
</style>
