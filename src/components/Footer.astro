---
import Brand from "@components/Brand.astro";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap">
    <div class="site-footer__grid">
      <div class="site-footer__brand">
        <Brand variant="dark" class="site-footer__brand-logo" />
        <p class="site-footer__tagline">
          Captación digital para clínicas dentales en Santiago. Google Ads, conversión y seguimiento medible, sin
          contratos largos.
        </p>
      </div>
      <div>
        <p class="site-footer__col-label">Contacto</p>
        <ul class="site-footer__links">
          <li><a href="/contacto/">Solicitar auditoría</a></li>
          <li><a href="mailto:contacto@agenciachucao.cl">contacto@agenciachucao.cl</a></li>
          <li><a href="https://wa.me/56922218674" target="_blank" rel="noopener">+56 9 2221 8674</a></li>
        </ul>
      </div>
      <div>
        <p class="site-footer__col-label">Sistema</p>
        <ul class="site-footer__links">
          <li><a href="#oferta">El Lead Engine</a></li>
          <li><a href="#proceso">Procedimiento</a></li>
          <li><a href="#precio">Inversión</a></li>
          <li><a href="#fundadores">Cupos iniciales</a></li>
          <li><a href="#faq">Preguntas</a></li>
        </ul>
      </div>
    </div>
    <div class="site-footer__bottom">
      <span>&copy; {year} Agencia Chucao &middot; Santiago, CL</span>
      <div class="site-footer__legal">
        <a href="/politica-de-cookies/">Política de cookies</a>
        <button class="site-footer__cookie-btn" data-cookie-preferences>Gestionar cookies</button>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: var(--bone);
    padding-top: clamp(3rem, 5vw, 4rem);
    padding-bottom: 1.5rem;
    border-top: 1px solid var(--ink-line);
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--ink-line);
  }
  @media (min-width: 800px) {
    .site-footer__grid {
      grid-template-columns: 1.4fr 1fr 1fr;
    }
  }

  .site-footer__brand-logo {
    margin-bottom: 1rem;
  }

  .site-footer__tagline {
    font-size: var(--t-md);
    line-height: 1.65;
    color: var(--muted-dark);
    max-width: 38ch;
    margin: 0;
  }

  .site-footer__col-label {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bone);
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .site-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }
  .site-footer a {
    color: var(--muted-dark);
    font-size: var(--t-md);
    line-height: 1.5;
    transition: color 160ms var(--ease-out);
  }
  .site-footer a:hover {
    color: var(--bone);
  }

  .site-footer__bottom {
    margin-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.04em;
    color: var(--muted-dark);
  }

  .site-footer__legal {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .site-footer__cookie-btn {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.04em;
    color: var(--muted-dark);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 160ms var(--ease-out);
  }
  .site-footer__cookie-btn:hover {
    color: var(--bone);
  }
</style>
