---
import Brand from "@components/Brand.astro";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap">
    <div class="site-footer__grid">
      <div class="site-footer__brand">
        <Brand variant="dark" class="site-footer__brand-logo" />
        <p class="site-footer__tagline">
          Agencia de marketing para clínicas dentales en Santiago. Google Ads, landing y seguimiento de pacientes, sin
          contratos largos.
        </p>
      </div>
      <div>
        <p class="site-footer__col-label">Contacto</p>
        <ul class="site-footer__links">
          <li><a href="/contacto/">Solicitar revisión</a></li>
          <li><a href="mailto:contacto@agenciachucao.cl">contacto@agenciachucao.cl</a></li>
          <li><a href="https://wa.me/56922218674" target="_blank" rel="noopener">+56 9 2221 8674</a></li>
        </ul>
      </div>
      <div>
        <p class="site-footer__col-label">Sistema</p>
        <ul class="site-footer__links">
          <li><a href="/#oferta">Sistema</a></li>
          <li><a href="/#proceso">Procedimiento</a></li>
          <li><a href="/#precio">Precio</a></li>
          <li><a href="/#faq">Preguntas</a></li>
        </ul>
      </div>
    </div>
    <div class="site-footer__bottom">
      <span>&copy; {year} Agencia Chucao &middot; Santiago, CL</span>
      <div class="site-footer__legal">
        <a href="/politica-de-cookies/">Política de cookies</a>
        <button class="site-footer__cookie-btn" data-cookie-preferences>Gestionar cookies</button>
      </div>
    </div>
  </div>
</footer>
