---
const year = new Date().getFullYear();
---

<footer class="foot">
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-brand">
        <a href="/" class="brand" aria-label="Agencia Chucao - inicio">
          <img class="mark" src="/images/assets/chucao-logo.svg" alt="" width="22" height="22" />
          <span><span class="light">agencia</span><span class="bold">chucao</span></span>
        </a>
        <p class="foot-tag">
          Captación digital para clínicas dentales en Santiago. Google Ads, conversión y seguimiento medible, sin
          contratos largos.
        </p>
      </div>
      <div>
        <p class="col-label">Contacto</p>
        <ul>
          <li><a href="/contacto/">Solicitar auditoría</a></li>
          <li><a href="mailto:contacto@agenciachucao.cl">contacto@agenciachucao.cl</a></li>
          <li><a href="https://wa.me/56922218674" target="_blank" rel="noopener">+56 9 2221 8674</a></li>
        </ul>
      </div>
      <div>
        <p class="col-label">Sistema</p>
        <ul>
          <li><a href="#oferta">El Lead Engine</a></li>
          <li><a href="#proceso">Procedimiento</a></li>
          <li><a href="#precio">Inversión</a></li>
          <li><a href="#fundadores">Cupos iniciales</a></li>
          <li><a href="#faq">Preguntas</a></li>
        </ul>
      </div>
    </div>
    <div class="foot-bottom">
      <span>&copy; {year} Agencia Chucao &middot; Santiago, CL</span>
      <div class="foot-legal">
        <a href="/politica-de-cookies/">Política de cookies</a>
        <button class="cookie-manage-btn" id="cookie-manage-btn">Gestionar preferencias</button>
      </div>
    </div>
  </div>
</footer>

<script>
  document.getElementById("cookie-manage-btn")?.addEventListener("click", () => {
    document.cookie = "chucao_consent=; max-age=0; path=/";
    window.location.reload();
  });
</script>

<style>
  .foot {
    background: var(--ink);
    color: var(--bone);
    padding-top: clamp(3rem, 5vw, 4rem);
    padding-bottom: 1.5rem;
    border-top: 1px solid var(--ink-line);
  }

  .foot-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--ink-line);
  }
  @media (min-width: 800px) {
    .foot-grid {
      grid-template-columns: 1.4fr 1fr 1fr;
    }
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--f-display);
    font-size: 0.95rem;
    letter-spacing: -0.01em;
    margin-bottom: 1rem;
  }
  .brand .mark {
    width: 22px;
    height: 22px;
    display: block;
  }
  .brand .light {
    font-weight: 400;
    color: var(--muted-dark);
  }
  .brand .bold {
    font-weight: 700;
    color: var(--bone);
  }

  .foot-tag {
    font-size: var(--t-md);
    line-height: 1.65;
    color: var(--muted-dark);
    max-width: 38ch;
    margin: 0;
  }

  .col-label {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bone);
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .foot ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }
  .foot a {
    color: var(--muted-dark);
    font-size: var(--t-md);
    line-height: 1.5;
    transition: color 160ms var(--ease-out);
  }
  .foot a:hover {
    color: var(--bone);
  }

  .foot-bottom {
    margin-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.04em;
    color: var(--muted-dark);
  }

  .foot-legal {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .cookie-manage-btn {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.04em;
    color: var(--muted-dark);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color 160ms var(--ease-out);
  }
  .cookie-manage-btn:hover {
    color: var(--bone);
  }
</style>
