---
import TrackedLink from "@components/TrackedLink.astro";

interface Props {
  spotsTotal: number;
  ctaHref: string;
}

const { ctaHref } = Astro.props;
---

<section class="section founding-section" id="fundadores" aria-labelledby="found-h2">
  <div class="wrap">
    <div class="tray">
      <span class="serial">Cupos iniciales</span>
      <span class="meta">Precio reducido · cierra al llenarse</span>
    </div>

    <div class="founding-section__grid">
      <div class="founding-section__intro">
        <h2 id="found-h2">Precio reducido para las primeras 2 clínicas.</h2>
        <p class="lede founding-section__lede">
          Estamos documentando resultados en el nicho dental. Por eso abrimos dos cupos iniciales con un valor menor al
          precio estándar.
        </p>
      </div>

      <div class="founding-section__details">
        <div class="founding-section__detail">
          <span class="founding-section__detail-key">Fee mensual</span>
          <span class="founding-section__detail-value">$950.000</span>
        </div>
        <div class="founding-section__detail">
          <span class="founding-section__detail-key">Instalación inicial</span>
          <span class="founding-section__detail-value">$500.000</span>
        </div>
        <div class="founding-section__detail">
          <span class="founding-section__detail-key">Pauta publicitaria</span>
          <span class="founding-section__detail-value founding-section__detail-value--text">Aparte</span>
        </div>
      </div>

      <div class="founding-section__note">
        <p>
          Al cerrarse los dos cupos, el precio sube a la banda estándar de $1.150.000 - $1.200.000/mes. Sin excepciones.
        </p>
      </div>

      <div class="founding-section__cta">
        <TrackedLink
          href={ctaHref}
          class="btn"
          id="founding-cta-btn"
          trackEvent="select_content"
          trackLabel="Solicita una revisión gratis"
          trackLocation="founding"
          trackDestination={ctaHref}
          trackCategory="cta"
        >
          Solicita una revisión gratis <svg class="arrow" aria-hidden="true"><use href="#i-arrow"></use></svg>
        </TrackedLink>
      </div>
    </div>
  </div>
</section>
