---
interface Props {
  spotsTotal: number;
  ctaHref: string;
}

const { spotsTotal, ctaHref } = Astro.props;
---

<section class="founding section-pad">
  <div class="container">
    <div class="founding-inner">
      <div class="founding-badge-wrap founding-reveal">
        <div class="founding-badge" aria-label={`${spotsTotal} cupos fundadores disponibles`}>
          <span class="badge-num">{spotsTotal}</span>
          <span class="badge-label">cupos<br />fundadores</span>
        </div>
        <div class="badge-line" aria-hidden="true"></div>
      </div>

      <div class="founding-body founding-reveal founding-reveal-delay-1">
        <p class="section-label">Oferta fundadora</p>
        <h2 class="founding-h2">Dos cuentas iniciales a precio de validación.</h2>

        <p class="founding-desc">
          Estamos abriendo dos cuentas para documentar resultados con el nicho dental. No es un descuento. Es una
          apuesta compartida: tú obtienes el sistema a precio reducido, nosotros obtenemos el caso para demostrar el
          modelo.
        </p>

        <div class="founding-details">
          <div class="founding-detail">
            <p class="detail-label">Fee fundador</p>
            <p class="detail-value">$950.000<span class="detail-unit">/mes</span></p>
          </div>
          <div class="founding-divider" aria-hidden="true"></div>
          <div class="founding-detail">
            <p class="detail-label">Setup</p>
            <p class="detail-value">$500.000<span class="detail-unit"> único</span></p>
          </div>
          <div class="founding-divider" aria-hidden="true"></div>
          <div class="founding-detail">
            <p class="detail-label">Pauta</p>
            <p class="detail-value detail-value--alt">Aparte</p>
          </div>
        </div>

        <p class="founding-caveat">
          Al cerrarse los dos cupos, el precio sube a la banda estándar de $1.150.000–$1.200.000/mes. Sin excepciones.
        </p>

        <a href={ctaHref} class="btn-primary founding-cta" id="founding-cta-btn">
          Reservar un cupo fundador
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById("founding-cta-btn")?.addEventListener("click", () => {
    if (typeof gtag !== "undefined") {
      gtag("event", "cta_click", { location: "founding" });
    }
  });
</script>

<style>
  .founding {
    background: var(--color-white);
  }

  .founding-inner {
    display: grid;
    gap: 4rem;
    align-items: start;
  }
  @media (min-width: 900px) {
    .founding-inner {
      grid-template-columns: 160px 1fr;
      gap: 5rem;
    }
  }

  .founding-badge-wrap {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 2rem;
  }
  @media (min-width: 900px) {
    .founding-badge-wrap {
      flex-direction: column;
      align-items: center;
      gap: 0;
    }
  }

  .founding-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 2px solid var(--color-orange);
    text-align: center;
    flex-shrink: 0;
  }
  @media (min-width: 900px) {
    .founding-badge {
      width: 140px;
      height: 140px;
    }
  }

  .badge-num {
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: 56px;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-orange);
  }

  .badge-label {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-olive);
    line-height: 1.4;
    text-align: center;
  }

  .badge-line {
    display: none;
  }
  @media (min-width: 900px) {
    .badge-line {
      display: block;
      width: 1px;
      flex: 1;
      background: var(--color-moss);
      margin-top: 2rem;
      min-height: 80px;
    }
  }

  .founding-h2 {
    font-size: clamp(26px, 3vw, 38px);
    font-weight: var(--text-h2-weight);
    letter-spacing: var(--text-h2-track);
    line-height: var(--text-h2-leading);
    color: var(--color-forest);
    margin-block: 0 1.5rem;
    max-width: 28ch;
  }

  .founding-desc {
    font-family: var(--font-serif);
    font-size: var(--text-lede-size);
    line-height: var(--text-lede-leading);
    color: var(--color-olive);
    max-width: 52ch;
    margin-bottom: 2.5rem;
  }

  .founding-details {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin-bottom: 1.75rem;
    border: 1px solid var(--color-moss);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .founding-detail {
    flex: 1;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .founding-divider {
    width: 1px;
    background: var(--color-moss);
    flex-shrink: 0;
  }

  .detail-label {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-olive);
  }

  .detail-value {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: clamp(16px, 2vw, 20px);
    color: var(--color-forest);
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .detail-value--alt {
    color: var(--color-olive);
    font-weight: 600;
  }

  .detail-unit {
    font-weight: 500;
    font-size: 0.65em;
    color: var(--color-olive);
    letter-spacing: 0;
  }

  .founding-caveat {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.65;
    color: var(--color-olive);
    font-style: italic;
    margin-bottom: 2.5rem;
    max-width: 50ch;
  }

  .founding-cta {
    font-size: 14px;
    padding: 1rem 2.25rem;
    display: inline-flex;
  }
</style>
