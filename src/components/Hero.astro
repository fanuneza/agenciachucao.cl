---
interface Props {
  headline: string;
  subheadline: string;
  ctaText: string;
  ctaHref: string;
}

const { headline, subheadline, ctaText, ctaHref } = Astro.props;
---

<section class="hero noise-bg">
  <span class="hero-ghost" aria-hidden="true">CHUCAO</span>

  <div class="container hero-inner">
    <div class="hero-content">
      <p class="section-label section-label-light hero-anim-1">Sistema de captación para clínicas dentales · Santiago</p>

      <h1 class="hero-h1 hero-anim-2">{headline}</h1>

      <p class="hero-lede hero-anim-3">{subheadline}</p>

      <div class="hero-actions hero-anim-4">
        <a href={ctaHref} class="btn-primary hero-cta-primary" id="hero-cta-btn">
          {ctaText}
        </a>
      </div>

      <div class="hero-trust hero-anim-5">
        <span class="trust-item">Implantología</span>
        <span class="trust-dot" aria-hidden="true">·</span>
        <span class="trust-item">Ortodoncia</span>
        <span class="trust-dot" aria-hidden="true">·</span>
        <span class="trust-item">Rehabilitación oral</span>
        <span class="trust-dot" aria-hidden="true">·</span>
        <span class="trust-item">Sin contratos largos</span>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById("hero-cta-btn")?.addEventListener("click", () => {
    if (typeof gtag !== "undefined") {
      gtag("event", "cta_click", { location: "hero" });
    }
  });
</script>

<style>
  .hero {
    background: var(--color-forest);
    color: var(--color-white);
    padding-top: clamp(1rem, 2.5vw, 2rem);
    padding-bottom: clamp(3.5rem, 6vw, 5.5rem);
    position: relative;
    overflow: hidden;
  }

  .hero-ghost {
    position: absolute;
    right: -0.05em;
    bottom: -0.15em;
    font-family: var(--font-sans);
    font-weight: 900;
    font-style: italic;
    font-size: clamp(100px, 18vw, 260px);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.05);
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
  }

  .hero-content {
    max-width: 64ch;
  }

  .hero-h1 {
    font-size: clamp(40px, 5vw, 68px);
    font-weight: var(--text-h1-weight);
    letter-spacing: var(--text-h1-track);
    line-height: var(--text-h1-leading);
    color: var(--color-white);
    margin-block: 1.25rem 1.5rem;
  }

  .hero-lede {
    font-family: var(--font-serif);
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    max-width: 54ch;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .hero-cta-primary {
    font-size: 14px;
    padding: 1rem 2rem;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }
  .trust-item {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.4);
  }
  .trust-dot {
    color: rgba(255, 255, 255, 0.2);
  }
</style>
