---
const waNumber = import.meta.env.PUBLIC_WA_NUMBER;
const message = 'Hola%2C%20vi%20Agencia%20Chucao%20y%20me%20interesa%20mejorar%20la%20presencia%20digital%20de%20mi%20negocio.%20%C2%BFTienen%20disponibilidad%20para%20conversar%3F';
const waHref = `https://wa.me/${waNumber}?text=${message}`;
---

<section class="hero noise-bg">
  <span class="hero-ghost" aria-hidden="true">CHUCAO</span>

  <div class="container hero-inner">
    <div class="hero-content">
      <p class="section-label section-label-light hero-anim-1">Agencia de marketing digital</p>

      <h1 class="hero-h1 hero-anim-2">
        Presencia digital<br />
        que <em class="accent-italic">trae clientes</em>,<br />
        no solo likes.
      </h1>

      <p class="hero-lede hero-anim-3">
        Gestión de redes sociales, estrategia de contenido, SEO técnico y desarrollo web para negocios chilenos que quieren resultados reales. Sin humo.
      </p>

      <div class="hero-actions hero-anim-4">
        <a
          href={waHref}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary hero-cta-primary"
          id="hero-wa-btn"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" class="hero-wa-icon">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Hablemos
        </a>
        <a href="/servicios/" class="btn-ghost">Ver servicios</a>
      </div>

      <div class="hero-trust hero-anim-5">
        <span class="trust-item">SEO técnico</span>
        <span class="trust-dot" aria-hidden="true">·</span>
        <span class="trust-item">Redes sociales</span>
        <span class="trust-dot" aria-hidden="true">·</span>
        <span class="trust-item">Desarrollo web</span>
        <span class="trust-dot" aria-hidden="true">·</span>
        <span class="trust-item">Google Business</span>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('hero-wa-btn')?.addEventListener('click', () => {
    if (typeof gtag !== 'undefined') {
      gtag('event', 'whatsapp_click_inline', {
        page_url: window.location.href,
        cta_label: 'Hablemos',
        service: 'home-hero',
      });
    }
  });
</script>

<style>
  .hero {
    background: var(--color-forest);
    color: var(--color-white);
    padding-top: clamp(1rem, 2.5vw, 2rem);
    padding-bottom: clamp(3.5rem, 6vw, 5.5rem);
    position: relative;
    overflow: hidden;
  }

  .hero-ghost {
    position: absolute;
    right: -0.05em;
    bottom: -0.15em;
    font-family: var(--font-sans);
    font-weight: 900;
    font-style: italic;
    font-size: clamp(100px, 18vw, 260px);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.05);
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
  }

  .hero-inner { position: relative; z-index: 2; }

  .hero-content { max-width: 64ch; }

  .hero-h1 {
    font-size: clamp(40px, 5vw, 68px);
    font-weight: var(--text-h1-weight);
    letter-spacing: var(--text-h1-track);
    line-height: var(--text-h1-leading);
    color: var(--color-white);
    margin-block: 1.25rem 1.5rem;
  }

  .hero-lede {
    font-family: var(--font-serif);
    font-size: clamp(16px, 2vw, 19px);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    max-width: 54ch;
    margin-bottom: 2.5rem;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .hero-cta-primary { font-size: 14px; padding: 1rem 2rem; }

  .hero-wa-icon {
    width: 18px;
    height: 18px;
    fill: currentColor;
    flex-shrink: 0;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
  }
  .trust-item {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.4);
  }
  .trust-dot { color: rgba(255, 255, 255, 0.2); }
</style>
