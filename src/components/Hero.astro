---
interface Props {
  headline: string;
  subheadline: string;
  ctaText: string;
  ctaHref: string;
}

const { headline, subheadline, ctaText, ctaHref } = Astro.props;

const headlineHtml = headline.replace("agendamientos", "<em>agendamientos</em>");
const subheadlineHtml = subheadline.replace("cuánto te cuesta", "<strong>cuánto te cuesta</strong>");
---

<section class="section dark hero" id="hero" aria-labelledby="hero-h1">
  <div class="wrap">
    <div class="tray">
      <span class="serial">Lead Engine dental</span>
      <span class="meta">Santiago, Chile</span>
    </div>

    <div class="hero-grid">
      <div>
        <h1 id="hero-h1" class="hero-headline" set:html={headlineHtml} />
        <p class="lede hero-lede" set:html={subheadlineHtml} />

        <div class="hero-actions">
          <a
            href={ctaHref}
            class="btn"
            id="hero-cta-btn"
            data-analytics-event="cta_click"
            data-analytics-location="hero"
          >
            {ctaText}
            <svg class="arrow" aria-hidden="true"><use href="#i-arrow"></use></svg>
          </a>
        </div>

        <p class="hero-trust">
          Sistema pensado para tratamientos de alto valor, donde cada consulta debe ser medible desde Google hasta
          WhatsApp.
        </p>
      </div>

      <aside class="flow-panel" aria-label="Flujo del sistema">
        <p class="flow-label">Cómo funciona el Lead Engine</p>
        <div class="flow-steps">
          <div class="flow-step">
            <span class="flow-dot" aria-hidden="true"></span>
            <span class="flow-name">Búsqueda en Google</span>
          </div>
          <span class="flow-connector" aria-hidden="true"></span>
          <div class="flow-step">
            <span class="flow-dot" aria-hidden="true"></span>
            <span class="flow-name">Landing</span>
          </div>
          <span class="flow-connector" aria-hidden="true"></span>
          <div class="flow-step">
            <span class="flow-dot" aria-hidden="true"></span>
            <span class="flow-name">WhatsApp</span>
          </div>
          <span class="flow-connector" aria-hidden="true"></span>
          <div class="flow-step">
            <span class="flow-dot" aria-hidden="true"></span>
            <span class="flow-name">Agenda</span>
          </div>
        </div>
        <div class="flow-meta">
          <p><span class="flow-meta-k">Foco</span> Implantes, ortodoncia, rehabilitación</p>
          <p><span class="flow-meta-k">Inversión</span> Desde $950.000/mes + pauta aparte</p>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .hero {
    border-top: 0;
    padding-top: clamp(2.5rem, 5vw, 4.5rem);
    padding-bottom: clamp(2rem, 4vw, 3.5rem);
    overflow: hidden;
  }
  .hero .tray {
    border-bottom-color: var(--ink-line);
    color: var(--muted-dark);
    margin-bottom: 1.25rem;
  }
  .hero-headline {
    color: var(--bone);
  }

  .hero-lede {
    margin-top: clamp(1rem, 2vw, 1.5rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 3.5rem);
  }
  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
      align-items: start;
    }
  }

  .hero-actions {
    margin-top: clamp(1.25rem, 2vw, 1.75rem);
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .hero-trust {
    margin-top: 1.25rem;
    font-size: var(--t-sm);
    line-height: 1.6;
    color: var(--muted-dark);
    max-width: 55ch;
  }

  .flow-panel {
    border: 1px solid var(--ink-line);
    background: var(--ink-2);
    padding: clamp(1.25rem, 2vw, 1.75rem);
  }

  .flow-label {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted-dark);
    margin: 0 0 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--ink-line);
  }

  .flow-steps {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.25rem;
  }

  .flow-step {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--ink);
    border: 1px solid var(--ink-line);
    padding: 0.5rem 0.75rem;
    font-family: var(--f-display);
    font-size: var(--t-sm);
    color: var(--bone);
    letter-spacing: -0.01em;
  }

  .flow-dot {
    width: 7px;
    height: 7px;
    background: var(--vermilion);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .flow-connector {
    display: inline-block;
    width: 1.25rem;
    height: 1px;
    background: var(--vermilion);
    flex-shrink: 0;
    opacity: 0.5;
  }

  .flow-meta {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--ink-line);
    display: grid;
    gap: 0.6rem;
  }

  .flow-meta p {
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    color: var(--bone);
    line-height: 1.5;
    margin: 0;
  }

  .flow-meta-k {
    color: var(--muted-dark);
    text-transform: uppercase;
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    margin-right: 0.5rem;
  }

  @media (max-width: 520px) {
    .flow-steps {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.5rem 0.35rem;
      align-items: center;
    }
    .flow-step {
      grid-column: 2;
    }
    .flow-connector {
      grid-column: 1;
      width: 1px;
      height: 0.75rem;
      justify-self: center;
    }
  }
</style>
