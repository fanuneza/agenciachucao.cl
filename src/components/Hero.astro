---
interface Props {
  headline: string;
  subheadline: string;
  ctaText: string;
  ctaHref: string;
}

const { headline, subheadline, ctaText, ctaHref } = Astro.props;

const headlineHtml = headline.replace("agendamientos", "<em>agendamientos</em>");
const subheadlineHtml = subheadline.replace("cuánto te cuesta", "<strong>cuánto te cuesta</strong>");
---

<section class="section dark hero" id="hero" aria-labelledby="hero-h1">
  <div class="wrap">
    <div class="tray">
      <span class="serial">§ 00 / Hero</span>
      <span class="meta">Sistema de captación · Clínicas dentales · Santiago</span>
    </div>

    <div class="hero-grid">
      <div>
        <h1 id="hero-h1" class="hero-headline" set:html={headlineHtml} />
        <p class="lede hero-lede" set:html={subheadlineHtml} />

        <div class="hero-actions">
          <a
            href={ctaHref}
            class="btn"
            id="hero-cta-btn"
            data-analytics-event="cta_click"
            data-analytics-location="hero"
          >
            {ctaText}
            <svg class="arrow" aria-hidden="true"><use href="#i-arrow"></use></svg>
          </a>
          <a href="#oferta" class="btn-ghost">Ver el sistema</a>
        </div>

        <p class="hero-trust">Sin contratos largos · Cupos fundadores disponibles · Respuesta en 24 h</p>
      </div>

      <aside class="specs" aria-label="Especificaciones del sistema">
        <div class="specs-row">
          <span class="k">Foco</span><span class="v">Implantes · Ortodoncia · Rehabilitación</span>
        </div>
        <div class="specs-row">
          <span class="k">Medición</span><span class="v">Gasto por evaluación y por tratamiento</span>
        </div>
        <div class="specs-row"><span class="k">Inversión</span><span class="v">Desde $950.000/mes + pauta</span></div>
        <div class="specs-row">
          <span class="k">Pauta</span><span class="v"><em>Aparte</em>, pagada por el cliente</span>
        </div>
        <div class="specs-row"><span class="k">Cupos abiertos</span><span class="v">02 / 02</span></div>
      </aside>
    </div>
  </div>
</section>

<style>
  .hero {
    border-top: 0;
    padding-top: clamp(2.5rem, 5vw, 4.5rem);
    padding-bottom: clamp(2rem, 4vw, 3.5rem);
    overflow: hidden;
  }
  .hero .tray {
    border-bottom-color: var(--ink-line);
    color: var(--muted-dark);
    margin-bottom: 1.25rem;
  }
  .hero-headline {
    color: var(--bone);
  }

  .hero-lede {
    margin-top: clamp(1rem, 2vw, 1.5rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: clamp(2rem, 4vw, 3.5rem);
  }
  @media (min-width: 900px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
      align-items: start;
    }
  }

  .hero-actions {
    margin-top: clamp(1.25rem, 2vw, 1.75rem);
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .hero-trust {
    margin-top: 1rem;
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.06em;
    color: var(--muted-dark);
    text-transform: uppercase;
  }

  /* Specs panel — parent grid ensures all rows share the same column widths */
  .specs {
    border: 1px solid var(--ink-line);
    background: var(--ink-2);
    padding: 1.5rem;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0;
  }
  .specs-row {
    display: contents;
  }
  .specs-row .k,
  .specs-row .v {
    padding: 0.95rem 0;
    border-bottom: 1px solid var(--ink-line);
    font-family: var(--f-mono);
    font-size: var(--t-sm);
  }
  .specs-row:last-child .k,
  .specs-row:last-child .v {
    border-bottom: 0;
  }
  .specs-row .k {
    padding-right: 1.25rem;
    color: var(--muted-dark);
    text-transform: uppercase;
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    white-space: nowrap;
  }
  .specs-row .v {
    color: var(--bone);
    text-align: right;
  }
</style>
