---
import TrackedLink from "@components/TrackedLink.astro";

interface Props {
  headline: string;
  subheadline: string;
  ctaText: string;
  ctaHref: string;
}

const { headline, subheadline, ctaText, ctaHref } = Astro.props;

const headlineHtml = headline.replace("agendamientos", "<em>agendamientos</em>");
const subheadlineHtml = subheadline.replace("cuánto te cuesta", "<strong>cuánto te cuesta</strong>");
---

<section class="section dark hero" id="hero" aria-labelledby="hero-h1">
  <div class="wrap" data-reveal-group>
    <div class="hero__grid">
      <div class="hero__intro">
        <div class="tray" data-reveal="fade">
          <span class="serial">Sistema de adquisición para clínicas dentales</span>
          <span class="meta">Santiago, Chile</span>
        </div>
        <h1 id="hero-h1" class="hero__headline" set:html={headlineHtml} data-reveal="rise" />
        <p class="lede hero__lede" set:html={subheadlineHtml} data-reveal />

        <div class="hero__actions" data-reveal>
          <TrackedLink
            href={ctaHref}
            class="btn"
            id="hero-cta-btn"
            trackEvent="select_content"
            trackLabel={ctaText}
            trackLocation="hero"
            trackDestination={ctaHref}
            trackCategory="cta"
          >
            {ctaText}
            <svg class="arrow" aria-hidden="true"><use href="#i-arrow"></use></svg>
          </TrackedLink>
        </div>

        <p class="hero__reassure" data-reveal="fade">
          Sin compromiso · respuesta en menos de 24 h · sin contratos largos. Pensado para tratamientos de alto valor,
          donde cada consulta es medible.
        </p>
      </div>

      <aside class="hero__flow" aria-label="Flujo del sistema" data-reveal>
        <p class="hero__flow-label">Flujo de adquisición</p>
        <ol class="hero__flow-steps" role="list">
          <li class="hero__flow-step">
            <span class="hero__flow-number" aria-hidden="true">01</span>
            <span class="hero__flow-name">Búsqueda en Google<small>Intención de tratamiento</small></span>
          </li>
          <li class="hero__flow-step">
            <span class="hero__flow-number" aria-hidden="true">02</span>
            <span class="hero__flow-name">Landing de conversión<small>Mensaje claro, siguiente paso</small></span>
          </li>
          <li class="hero__flow-step">
            <span class="hero__flow-number" aria-hidden="true">03</span>
            <span class="hero__flow-name">Respuesta por WhatsApp<small>Conversación y seguimiento</small></span>
          </li>
          <li class="hero__flow-step">
            <span class="hero__flow-number" aria-hidden="true">04</span>
            <span class="hero__flow-name">Paciente agendado<small>Confirmación de evaluación</small></span>
          </li>
        </ol>
        <div class="hero__flow-meta">
          <p><span class="hero__flow-meta-key">Foco</span> Implantes, ortodoncia, rehabilitación</p>
          <p><span class="hero__flow-meta-key">Inversión</span> Desde $950.000/mes + pauta aparte</p>
        </div>
      </aside>
    </div>
  </div>
</section>
