---
import type { PortfolioProject } from '@data/portfolio';

interface Props {
  project: PortfolioProject;
}

const { project } = Astro.props;
---

{project.comingSoon ? (
  <div class="port-card port-card--soon">
    <div class="port-soon-badge">Próximamente</div>
    <div class="port-soon-body">
      <span class="port-category">{project.category}</span>
      <p class="port-soon-text">Nuevo proyecto en camino</p>
    </div>
  </div>
) : project.url ? (
  <a
    href={project.url}
    target="_blank"
    rel="noopener noreferrer"
    class="port-card"
    data-project={project.name}
    id={`port-${project.name.toLowerCase().replace(/\s+/g, '-')}`}
  >
    <div class="port-img-wrap">
      {project.screenshot && (
        <img
          src={project.screenshot}
          alt={`Captura de pantalla de ${project.name}`}
          width="600"
          height="400"
          loading="lazy"
          class="port-img"
        />
      )}
    </div>
    <div class="port-body">
      <span class="port-category">{project.category}</span>
      <h3 class="port-name">{project.name}</h3>
      <p class="port-desc">{project.description}</p>
      <span class="port-link">Ver proyecto <span aria-hidden="true">↗</span></span>
    </div>
  </a>
) : (
  <div
    class="port-card"
    id={`port-${project.name.toLowerCase().replace(/\s+/g, '-')}`}
  >
    <div class="port-img-wrap">
      {project.screenshot && (
        <img
          src={project.screenshot}
          alt={`Captura de pantalla de ${project.name}`}
          width="600"
          height="400"
          loading="lazy"
          class="port-img"
        />
      )}
    </div>
    <div class="port-body">
      <span class="port-category">{project.category}</span>
      <h3 class="port-name">{project.name}</h3>
      <p class="port-desc">{project.description}</p>
    </div>
  </div>
)}

<script>
  document.querySelectorAll<HTMLAnchorElement>('.port-card[data-project]').forEach((card) => {
    card.addEventListener('click', () => {
      if (typeof gtag !== 'undefined') {
        gtag('event', 'portfolio_link_click', { project_name: card.dataset.project });
      }
    });
  });
</script>

<style>
  .port-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-white);
    border: 1px solid var(--color-moss);
    border-radius: var(--radius-sm);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s var(--ease-spring), box-shadow 0.3s;
  }
  .port-card:not(.port-card--soon):hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(28, 46, 26, 0.1);
  }
  .port-card:not(.port-card--soon):focus-visible {
    outline: 2px solid var(--color-orange);
    outline-offset: 2px;
  }

  /* Soon card */
  .port-card--soon {
    cursor: default;
    opacity: 0.6;
    flex-direction: row;
    align-items: center;
    gap: 1.25rem;
    padding: 1.75rem 2rem;
    min-height: 120px;
  }
  .port-soon-badge {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-olive);
    background: var(--color-moss);
    padding: 4px 10px;
    border-radius: var(--radius-md);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .port-soon-text {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-olive);
  }

  /* Image */
  .port-img-wrap {
    width: 100%;
    aspect-ratio: 3 / 2;
    background: var(--color-moss);
    overflow: hidden;
    border-bottom: 1px solid var(--color-moss);
  }
  .port-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s var(--ease-spring);
  }
  .port-card:hover .port-img { transform: scale(1.03); }

  /* Body */
  .port-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .port-category {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-orange);
  }

  .port-name {
    font-size: var(--text-h4-size);
    font-weight: var(--text-h4-weight);
    color: var(--color-forest);
  }

  .port-desc {
    font-family: var(--font-serif);
    font-size: 14px;
    line-height: 1.65;
    color: var(--color-olive);
    flex: 1;
  }

  .port-link {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin-top: 0.5rem;
  }
</style>
