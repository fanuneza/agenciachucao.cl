---
import type { Service } from '@data/services';
import BaseLayout from '@layouts/BaseLayout.astro';

interface Props {
  service: Service;
}

const { service } = Astro.props;

const waNumber = import.meta.env.PUBLIC_WA_NUMBER;
const waHref = `https://wa.me/${waNumber}?text=${service.cta.whatsappMessage}`;
const secondaryHref = '/portafolio/';

// Split multi-paragraph copy into <p> blocks
const problemaParagraphs = service.problema.split(/\n\n+/).filter(Boolean);
const solucionParagraphs = service.solucion.split(/\n\n+/).filter(Boolean);

const pageDescription = `${service.headline} ${solucionParagraphs[0] ?? ''}`.slice(0, 158) + '…';
---

<BaseLayout title={service.name} description={pageDescription}>

  <!-- Hero -->
  <header class="svc-hero noise-bg">
    <div class="container svc-hero-inner">
      <p class="section-label section-label-light hero-anim-1">Servicio</p>
      <h1 class="svc-h1 hero-anim-2">{service.headline}</h1>
      <div class="svc-hero-actions hero-anim-3">
        <a
          href={waHref}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary svc-cta-btn"
          id="svc-wa-btn"
          data-service={service.name}
        >
          {service.cta.primary}
        </a>
        {service.cta.secondary && (
          <a href={secondaryHref} class="btn-ghost">{service.cta.secondary}</a>
        )}
      </div>
    </div>
  </header>

  <!-- El problema -->
  <section class="svc-section section-py svc-problema">
    <div class="container svc-two-col">
      <div class="svc-col-label">
        <p class="section-label">El problema</p>
      </div>
      <div class="svc-col-body scroll-reveal">
        {problemaParagraphs.map((para) => (
          <p class="svc-body-text">{para}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- Lo que hacemos -->
  <section class="svc-section section-py svc-solucion">
    <div class="container svc-two-col">
      <div class="svc-col-label">
        <p class="section-label">Lo que hacemos</p>
      </div>
      <div class="svc-col-body scroll-reveal">
        {solucionParagraphs.map((para) => (
          <p class="svc-body-text">{para}</p>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA section -->
  <section class="svc-cta-section noise-bg">
    <div class="container svc-cta-inner scroll-reveal">
      <div class="svc-cta-text">
        <h2 class="svc-cta-title">{service.cta.primary}</h2>
        <p class="svc-cta-sub">
          Una conversación sin compromiso. Te decimos con honestidad si podemos ayudarte y cómo.
        </p>
      </div>
      <div class="svc-cta-buttons">
        <a
          href={waHref}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
          id="svc-bottom-wa-btn"
          data-service={service.name}
        >
          {service.cta.primary}
        </a>
        <a href={secondaryHref} class="btn-ghost">Ver portafolio</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script define:vars={{ serviceName: service.name }}>
  // service_page_view on load
  document.addEventListener('DOMContentLoaded', () => {
    if (typeof gtag !== 'undefined') {
      gtag('event', 'service_page_view', { service_name: serviceName });
    }
  });

  // whatsapp_click_inline on CTA clicks
  ['svc-wa-btn', 'svc-bottom-wa-btn'].forEach((id) => {
    document.getElementById(id)?.addEventListener('click', () => {
      if (typeof gtag !== 'undefined') {
        gtag('event', 'whatsapp_click_inline', {
          page_url: window.location.href,
          cta_label: document.getElementById(id)?.textContent?.trim() ?? '',
          service: serviceName,
        });
      }
    });
  });
</script>

<style>
  /* Hero */
  .svc-hero {
    background: var(--color-forest);
    color: var(--color-white);
    padding-block: clamp(4rem, 10vw, 7rem);
  }
  .svc-hero-inner { max-width: 72ch; }

  .svc-h1 {
    font-size: var(--text-h1-size);
    font-weight: var(--text-h1-weight);
    letter-spacing: var(--text-h1-track);
    line-height: var(--text-h1-leading);
    color: var(--color-white);
    margin-block: 1.25rem 2.5rem;
  }

  .svc-hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .svc-cta-btn { font-size: 14px; padding: 1rem 2rem; }

  /* Two-column body layout */
  .svc-section { background: var(--color-sage); }
  .svc-solucion { background: var(--color-white); }

  .svc-two-col {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .svc-two-col {
      grid-template-columns: 200px 1fr;
      gap: 4rem;
      align-items: start;
    }
  }

  .svc-col-label { padding-top: 0.25rem; }

  .svc-col-body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 68ch;
  }

  .svc-body-text {
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.8;
    color: var(--color-black);
  }

  /* Bottom CTA */
  .svc-cta-section {
    background: var(--color-forest);
    padding-block: clamp(4rem, 8vw, 7rem);
  }
  .svc-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    flex-wrap: wrap;
  }
  .svc-cta-text { max-width: 52ch; }
  .svc-cta-title {
    font-size: var(--text-h2-size);
    font-weight: var(--text-h2-weight);
    letter-spacing: var(--text-h2-track);
    color: var(--color-white);
    margin-bottom: 0.875rem;
  }
  .svc-cta-sub {
    font-family: var(--font-serif);
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
  }
  .svc-cta-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }
</style>
