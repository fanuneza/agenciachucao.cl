---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

const serviceBadge: Record<string, string> = {
  'redes-sociales':  'Redes Sociales',
  'seo':             'SEO',
  'desarrollo-web':  'Desarrollo Web',
  'google-business': 'Google Business',
  'contenido':       'Contenido',
  'email-marketing': 'Email Marketing',
  'publicidad':      'Publicidad',
  'default':         'Marketing Digital',
};

const wordCount = post.body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.ceil(wordCount / 200);
const badge = serviceBadge[post.data.service ?? 'default'] ?? 'Marketing Digital';

const date = post.data.publishDate.toLocaleDateString('es-CL', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/blog/${post.slug}/`} class="blog-card">
  <div class="blog-card-meta">
    <span class="blog-card-badge">{badge}</span>
    <span class="blog-card-date">{date}</span>
  </div>
  <h3 class="blog-card-title">{post.data.title}</h3>
  <p class="blog-card-desc">{post.data.description}</p>
  <div class="blog-card-footer">
    <span class="blog-card-read">{readingTime} min de lectura</span>
    <span class="blog-card-arrow">→</span>
  </div>
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 0.875rem;
    background: var(--color-white);
    border: 1px solid var(--color-moss);
    border-radius: var(--radius-sm);
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s var(--ease-spring), box-shadow 0.3s;
  }
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(28, 46, 26, 0.08);
  }
  .blog-card:focus-visible {
    outline: 2px solid var(--color-orange);
    outline-offset: 2px;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .blog-card-badge {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-orange);
    background: var(--color-orange-pale);
    padding: 3px 8px;
    border-radius: var(--radius-sm);
  }

  .blog-card-date {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--color-olive);
  }

  .blog-card-title {
    font-size: var(--text-h4-size);
    font-weight: var(--text-h4-weight);
    line-height: var(--text-h4-leading);
    color: var(--color-forest);
    min-height: calc(18px * 1.35 * 2);
  }

  .blog-card-desc {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-olive);
    flex: 1;
  }

  .blog-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-moss);
  }

  .blog-card-read {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--color-olive);
  }

  .blog-card-arrow {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 14px;
    color: var(--color-orange);
    transition: transform 0.2s var(--ease-spring);
  }
  .blog-card:hover .blog-card-arrow { transform: translateX(4px); }
</style>
