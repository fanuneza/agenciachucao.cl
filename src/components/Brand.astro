---
interface Props {
  class?: string;
  variant?: "light" | "dark";
}

const { class: className, variant = "light" } = Astro.props;
---

<a href="/" class:list={["brand", variant === "dark" && "brand--dark", className]} aria-label="Agencia Chucao - inicio">
  <img class="brand__mark" src="/images/assets/chucao-logo.svg" alt="" width="22" height="22" />
  <span class="brand__wordmark">
    <span class="brand__wordmark--light">agencia</span><span class="brand__wordmark--bold">chucao</span>
  </span>
</a>

<style>
  .brand {
    --brand-light: var(--graphite);
    --brand-bold: var(--ink);

    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--f-display);
    font-size: 0.95rem;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }
  .brand--dark {
    --brand-light: var(--muted-dark);
    --brand-bold: var(--bone);
  }
  .brand:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 4px;
  }

  .brand__mark {
    width: 22px;
    height: 22px;
    display: block;
  }

  .brand__wordmark--light {
    font-weight: 400;
    color: var(--brand-light);
  }
  .brand__wordmark--bold {
    font-weight: 700;
    color: var(--brand-bold);
  }
</style>
