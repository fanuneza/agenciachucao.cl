---
import type { Service } from '@data/services';

interface Props {
  service: Service;
  index: number;
}

const { service, index } = Astro.props;
const ordinal = String(index + 1).padStart(2, '0');
---

<a href={`/servicios/${service.id}/`} class="service-card">
  <span class="svc-bar" aria-hidden="true"></span>
  <span class="svc-ghost-num" aria-hidden="true">{ordinal}</span>

  <div class="svc-body">
    <h3 class="svc-name">{service.name}</h3>
    <p class="svc-headline">{service.headline}</p>
    <span class="svc-link">
      Ver servicio
      <span class="svc-arrow" aria-hidden="true">→</span>
    </span>
  </div>
</a>

<style>
  .service-card {
    display: block;
    background: var(--color-white);
    border: 1px solid var(--color-moss);
    border-radius: var(--radius-sm);
    padding: 2.25rem 2rem 2rem;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s var(--ease-spring), box-shadow 0.3s;
  }
  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 48px rgba(28, 46, 26, 0.1);
  }

  .svc-bar {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--color-orange);
    transition: background-color 0.3s;
  }
  .service-card:hover .svc-bar { background: var(--color-forest); }

  .svc-ghost-num {
    position: absolute;
    top: -0.25em;
    right: 0.25rem;
    font-family: var(--font-sans);
    font-weight: 900;
    font-size: 100px;
    line-height: 1;
    color: var(--color-sage);
    pointer-events: none;
    user-select: none;
  }

  .svc-body {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    z-index: 1;
  }

  .svc-name {
    font-size: var(--text-h4-size);
    font-weight: var(--text-h4-weight);
    line-height: var(--text-h4-leading);
    color: var(--color-forest);
  }

  .svc-headline {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-olive);
    flex: 1;
  }

  .svc-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin-top: 0.75rem;
    transition: gap 0.2s;
  }
  .service-card:hover .svc-link { gap: 0.65rem; }

  .svc-arrow { transition: transform 0.2s var(--ease-spring); }
  .service-card:hover .svc-arrow { transform: translateX(3px); }
</style>
