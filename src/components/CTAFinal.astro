---
import TrackedLink from "@components/TrackedLink.astro";

interface Props {
  headline: string;
  ctaText: string;
  ctaHref: string;
  whatsappHref: string;
}

const { ctaText, ctaHref, whatsappHref } = Astro.props;
---

<section class="section dark cta-section" id="contacto" aria-labelledby="final-h2">
  <div class="wrap">
    <div class="tray">
      <span class="serial">§ 08 / Contacto</span>
      <span class="meta">Auditoría gratuita</span>
    </div>

    <div class="cta-section__content">
      <h2 id="final-h2">Revisemos si tu clínica puede generar más agendamientos desde Google.</h2>
      <p class="lede cta-section__lede">
        Revisamos tu situación y te decimos si el sistema tiene sentido para tu clínica. Sin presentación, sin
        compromiso. Solo una conversación con orientación clara.
      </p>

      <div class="cta-section__actions">
        <TrackedLink
          href={ctaHref}
          class="btn cta-section__btn"
          id="footer-cta-btn"
          trackEvent="select_content"
          trackLabel={ctaText}
          trackLocation="footer_cta"
          trackDestination={ctaHref}
          trackCategory="cta"
        >
          {ctaText}
          <svg class="arrow" aria-hidden="true"><use href="#i-arrow"></use></svg>
        </TrackedLink>
        <TrackedLink
          href={whatsappHref}
          class="cta-section__whatsapp"
          target="_blank"
          rel="noopener noreferrer"
          id="footer-wa-btn"
          trackEvent="contact"
          trackLabel="Escribir por WhatsApp"
          trackLocation="footer"
          trackDestination={whatsappHref}
          trackCategory="whatsapp"
        >
          <svg aria-hidden="true"><use href="#i-wa"></use></svg>
          Escribir por WhatsApp
        </TrackedLink>
        <p class="cta-section__microcopy">Te respondemos con una primera orientación clara. Sin venta agresiva.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section__content {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2rem);
  }
  @media (min-width: 900px) {
    .cta-section__content {
      grid-template-columns: 1.4fr 1fr;
      gap: clamp(2rem, 5vw, 4rem);
      align-items: end;
    }
    .cta-section__actions {
      grid-column: 2;
      grid-row: 1 / 3;
    }
  }

  .cta-section__lede {
    margin-top: 1.25rem;
    max-width: 55ch;
  }

  .cta-section__actions {
    display: grid;
    gap: 0.85rem;
    align-content: end;
    padding-top: 0.5rem;
  }

  .cta-section__btn {
    width: 100%;
  }

  .cta-section__whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    border: 1px solid var(--ink-line);
    padding: 0.95rem 1.4rem;
    min-height: 48px;
    color: var(--bone);
    font-family: var(--f-display);
    font-size: var(--t-md);
    background: transparent;
    transition:
      border-color 160ms var(--ease-out),
      background 160ms var(--ease-out);
  }
  .cta-section__whatsapp:hover {
    border-color: var(--bone);
    background: var(--ink-2);
  }
  .cta-section__whatsapp svg {
    width: 1em;
    height: 1em;
    fill: currentColor;
  }

  .cta-section__microcopy {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    color: var(--muted-dark);
    letter-spacing: 0.04em;
    text-align: center;
    margin: 0.25rem 0 0;
  }
</style>
