---
interface Props {
  headline: string;
  ctaText: string;
  ctaHref: string;
  whatsappHref: string;
}

const { ctaText, ctaHref, whatsappHref } = Astro.props;
---

<section class="section dark final-section" id="contacto" aria-labelledby="final-h2">
  <div class="wrap">
    <div class="tray">
      <span class="serial">§ 08 / Contacto</span>
      <span class="meta">Auditoría gratuita</span>
    </div>

    <div class="final">
      <h2 id="final-h2">Revisemos si tu clínica puede generar más agendamientos desde Google.</h2>
      <p class="lede final-lede">
        Revisamos tu situación y te decimos si el sistema tiene sentido para tu clínica. Sin presentación, sin
        compromiso. Solo una conversación con orientación clara.
      </p>

      <div class="final-actions">
        <a
          href={ctaHref}
          class="btn final-btn"
          id="footer-cta-btn"
          data-analytics-event="cta_click"
          data-analytics-location="footer_cta"
        >
          {ctaText}
          <svg class="arrow" aria-hidden="true"><use href="#i-arrow"></use></svg>
        </a>
        <a
          href={whatsappHref}
          class="wa-link"
          target="_blank"
          rel="noopener noreferrer"
          id="footer-wa-btn"
          data-analytics-event="whatsapp_click"
          data-analytics-location="footer"
        >
          <svg aria-hidden="true"><use href="#i-wa"></use></svg>
          Escribir por WhatsApp
        </a>
        <p class="final-microcopy">Te respondemos con una primera orientación clara. Sin venta agresiva.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .final {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 2rem);
  }
  @media (min-width: 900px) {
    .final {
      grid-template-columns: 1.4fr 1fr;
      gap: clamp(2rem, 5vw, 4rem);
      align-items: end;
    }
    .final-actions {
      grid-column: 2;
      grid-row: 1 / 3;
    }
  }

  .final-lede {
    margin-top: 1.25rem;
    max-width: 55ch;
  }

  .final-actions {
    display: grid;
    gap: 0.85rem;
    align-content: end;
    padding-top: 0.5rem;
  }

  .final-btn {
    width: 100%;
  }

  .wa-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    border: 1px solid var(--ink-line);
    padding: 0.95rem 1.4rem;
    min-height: 48px;
    color: var(--bone);
    font-family: var(--f-display);
    font-size: var(--t-md);
    background: transparent;
    transition:
      border-color 160ms var(--ease-out),
      background 160ms var(--ease-out);
  }
  .wa-link:hover {
    border-color: var(--bone);
    background: var(--ink-2);
  }
  .wa-link svg {
    width: 1em;
    height: 1em;
    fill: currentColor;
  }

  .final-microcopy {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    color: var(--muted-dark);
    letter-spacing: 0.04em;
    text-align: center;
    margin: 0.25rem 0 0;
  }
</style>
