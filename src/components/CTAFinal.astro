---
interface Props {
  headline: string;
  ctaText: string;
  ctaHref: string;
  whatsappHref: string;
}

const { headline, ctaText, ctaHref, whatsappHref } = Astro.props;
---

<section class="cta-final noise-bg">
  <div class="container cta-final-inner">
    <div class="cta-final-text cta-reveal">
      <p class="section-label section-label-light">¿Listo para empezar?</p>
      <h2 class="cta-final-h2">{headline}</h2>
      <p class="cta-final-lede">Sin compromiso. Sin presentación de 40 diapositivas. Solo una conversación honesta sobre si el sistema tiene sentido para tu clínica.</p>
    </div>

    <div class="cta-final-actions cta-reveal cta-reveal-delay-1">
      <a href={ctaHref} class="btn-primary cta-final-btn" id="footer-cta-btn">
        {ctaText}
      </a>
      <a href={whatsappHref} class="cta-wa-link" target="_blank" rel="noopener noreferrer" id="footer-wa-btn">
        <svg viewBox="0 0 24 24" aria-hidden="true" class="cta-wa-icon">
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path>
        </svg>
        Escribir por WhatsApp
      </a>
    </div>
  </div>
</section>

<script>
  document.getElementById("footer-cta-btn")?.addEventListener("click", () => {
    if (typeof gtag !== "undefined") {
      gtag("event", "cta_click", { location: "footer_cta" });
    }
  });
  document.getElementById("footer-wa-btn")?.addEventListener("click", () => {
    if (typeof gtag !== "undefined") {
      gtag("event", "whatsapp_click", { page: window.location.href });
    }
  });
</script>

<style>
  .cta-final {
    background: var(--color-forest);
    color: var(--color-white);
    padding-block: clamp(5rem, 10vw, 9rem);
  }

  .cta-final-inner {
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 900px) {
    .cta-final-inner {
      grid-template-columns: 1fr auto;
      gap: 5rem;
    }
  }

  .cta-final-h2 {
    font-size: clamp(30px, 4vw, 52px);
    font-weight: var(--text-h2-weight);
    letter-spacing: var(--text-h2-track);
    line-height: 1.15;
    color: var(--color-white);
    margin-block: 0.5rem 1.25rem;
    max-width: 30ch;
  }

  .cta-final-lede {
    font-family: var(--font-serif);
    font-size: var(--text-body-size);
    line-height: var(--text-body-leading);
    color: rgba(255, 255, 255, 0.55);
    max-width: 48ch;
  }

  .cta-final-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
    flex-shrink: 0;
  }
  @media (min-width: 900px) {
    .cta-final-actions {
      align-items: center;
    }
  }

  .cta-final-btn {
    font-size: 14px;
    padding: 1.125rem 2.5rem;
    white-space: nowrap;
  }

  .cta-wa-link {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.15s;
    white-space: nowrap;
  }
  .cta-wa-link:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  .cta-wa-icon {
    width: 16px;
    height: 16px;
    fill: currentColor;
    flex-shrink: 0;
  }
</style>
