---
import ContactForm from "@components/ContactForm.astro";

interface Props {
  headline: string;
}

const { headline } = Astro.props;
---

<section class="section cta-section" id="contacto" aria-labelledby="final-h2">
  <div class="wrap">
    <div class="cta-section__content">
      <div class="cta-section__intro" data-reveal-group>
        <h2 id="final-h2" data-reveal="rise">{headline}</h2>
        <p class="lede cta-section__lede" data-reveal="fade">
          Déjanos tus datos y revisamos tu situación: te decimos si el sistema tiene sentido para tu clínica. Sin
          presentación, sin compromiso. Solo una conversación con orientación clara.
        </p>
        <ul class="cta-section__assurances" role="list" data-reveal="fade">
          <li>Respuesta en menos de 24 h hábiles.</li>
          <li>Sin venta agresiva: te decimos si no calzas.</li>
          <li>Mes a mes, sin contratos largos.</li>
        </ul>
      </div>

      <div class="cta-section__form">
        <ContactForm />
      </div>
    </div>
  </div>
</section>
