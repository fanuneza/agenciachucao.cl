---
interface Props {
  headline: string;
  ctaText: string;
  ctaHref: string;
  whatsappHref: string;
}

const { headline, ctaText, ctaHref, whatsappHref } = Astro.props;
---

<section class="section dark final-section" id="contacto" aria-labelledby="final-h2">
  <div class="wrap">
    <div class="tray">
      <span class="serial">§ 08 / Contacto</span>
      <span class="meta">Auditoría gratuita · respuesta en 24 h</span>
    </div>

    <div class="final">
      <div>
        <h2 id="final-h2" set:html={headline.replace("paciente nuevo", "<em>paciente nuevo</em>")}></h2>
        <p class="lede" style="margin-top:1.5rem;">Revisamos tu situación y te decimos si el sistema tiene sentido para tu clínica. Sin presentación, sin compromiso. Solo una conversación con números reales.</p>
      </div>
      <div class="final-actions">
        <a href={ctaHref} class="btn" style="width:100%" id="footer-cta-btn">
          {ctaText} <svg class="arrow" aria-hidden="true"><use href="#i-arrow"/></svg>
        </a>
        <a href={whatsappHref} class="wa-link" target="_blank" rel="noopener noreferrer" id="footer-wa-btn">
          <svg aria-hidden="true"><use href="#i-wa"/></svg>
          Escribir por WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById("footer-cta-btn")?.addEventListener("click", () => {
    if (typeof gtag !== "undefined") {
      gtag("event", "cta_click", { location: "footer_cta" });
    }
  });
  document.getElementById("footer-wa-btn")?.addEventListener("click", () => {
    if (typeof gtag !== "undefined") {
      gtag("event", "whatsapp_click", { page: window.location.href });
    }
  });
</script>

<style>
  .final {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.75rem, 3vw, 2.5rem);
    align-items: end;
  }
  @media (min-width: 900px) { .final { grid-template-columns: 1.4fr 1fr; } }

  .final-actions {
    display: grid;
    gap: 0.85rem;
    align-content: end;
  }

  .wa-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    border: 1px solid var(--ink-line);
    padding: 0.95rem 1.4rem;
    min-height: 48px;
    color: var(--bone);
    font-family: var(--f-display);
    font-size: var(--t-md);
    background: transparent;
    transition: border-color 160ms var(--ease-out), background 160ms var(--ease-out);
  }
  .wa-link:hover { border-color: var(--bone); background: var(--ink-2); }
  .wa-link svg { width: 1em; height: 1em; fill: currentColor; }

  /* Italic serif accent on h2 em */
  :global(#contacto h2 em) {
    font-style: italic;
    font-family: var(--f-serif);
    font-weight: 400;
    letter-spacing: -0.015em;
  }
</style>
