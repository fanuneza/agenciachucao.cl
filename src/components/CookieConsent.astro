---
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
---

<div class="cookie-banner" id="cookie-banner" hidden aria-live="polite" role="region" aria-label="Aviso de cookies">
  <div class="cookie-inner wrap">
    <p class="cookie-text">
      Usamos cookies propias para analizar el tráfico de nuestra web (Google Analytics). Puedes aceptar o rechazar su uso.
      <a href="/politica-de-cookies/" class="cookie-link">Ver política de cookies</a>
    </p>
    <div class="cookie-actions">
      <button class="btn cookie-btn" id="cookie-accept">Aceptar</button>
      <button class="btn btn-secondary cookie-btn" id="cookie-reject">Rechazar</button>
    </div>
  </div>
</div>

<script define:vars={{ ga4Id }}>
  function getCookie(name) {
    return document.cookie
      .split("; ")
      .find((row) => row.startsWith(name + "="))
      ?.split("=")[1];
  }

  function setCookie(name, value) {
    document.cookie = `${name}=${value}; max-age=31536000; path=/; SameSite=Lax`;
  }

  function initGA4() {
    const script = document.createElement("script");
    script.async = true;
    script.src = `https://www.googletagmanager.com/gtag/js?id=${ga4Id}`;
    document.head.appendChild(script);

    window.dataLayer = window.dataLayer || [];
    function gtag() { window.dataLayer.push(arguments); }
    window.gtag = gtag;
    gtag("js", new Date());
    gtag("config", ga4Id);
  }

  const banner = document.getElementById("cookie-banner");
  const consent = getCookie("chucao_consent");

  if (consent === "accepted") {
    initGA4();
  } else if (!consent) {
    banner?.removeAttribute("hidden");
  }

  document.getElementById("cookie-accept")?.addEventListener("click", () => {
    setCookie("chucao_consent", "accepted");
    initGA4();
    banner?.remove();
  });

  document.getElementById("cookie-reject")?.addEventListener("click", () => {
    setCookie("chucao_consent", "rejected");
    banner?.remove();
  });
</script>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: var(--ink);
    border-top: 1px solid var(--ink-line);
  }

  .cookie-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-block: 1.25rem;
  }

  .cookie-text {
    font-family: var(--f-text);
    font-size: var(--t-sm);
    color: var(--muted-dark);
    line-height: 1.6;
    max-width: 60ch;
    margin: 0;
  }

  .cookie-link {
    color: var(--vermilion);
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-left: 0.375rem;
    transition: color 160ms var(--ease-out);
  }
  .cookie-link:hover { color: var(--bone); }

  .cookie-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .cookie-btn {
    font-size: var(--t-xs);
    padding: 0.6rem 1rem;
    min-height: 36px;
  }

  /* Secondary button on dark banner */
  .cookie-btn.btn-secondary {
    --fg: var(--bone);
    --bd: rgba(178, 174, 164, 0.35);
  }
  .cookie-btn.btn-secondary:hover {
    --bg: var(--bone);
    --fg: var(--ink);
    border-color: var(--bone);
  }
</style>
