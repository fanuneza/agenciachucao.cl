<div class="cookie-banner" id="cookie-banner" hidden aria-live="polite" role="region" aria-label="Aviso de cookies">
  <div class="cookie-banner__inner wrap">
    <p class="cookie-banner__text">
      Usamos Google Analytics 4 a través de Google Tag Manager solo si aceptas. No cargamos scripts de analítica antes
      de tu consentimiento.
      <a href="/politica-de-cookies/" class="cookie-banner__link">Ver política de cookies</a>
    </p>
    <div class="cookie-banner__actions">
      <button class="btn cookie-banner__btn" id="cookie-accept">Aceptar</button>
      <button class="btn btn-secondary cookie-banner__btn" id="cookie-reject">Rechazar</button>
    </div>
  </div>
</div>
