---
const waNumber = import.meta.env.PUBLIC_WA_NUMBER;
const waMessage = encodeURIComponent(
  "Hola, vi Agencia Chucao y me interesa el Lead Engine para mi clínica dental."
);
---

<a
  href={`https://wa.me/${waNumber}?text=${waMessage}`}
  class="wa-float"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escribir por WhatsApp"
  id="wa-float-btn"
  data-wa={waNumber}
>
  <span class="dot" aria-hidden="true"></span>
  <svg aria-hidden="true"><use href="#i-wa"/></svg>
  <span class="lbl">WhatsApp · respuesta &lt; 24 h</span>
</a>

<script>
  const btn = document.getElementById("wa-float-btn") as HTMLAnchorElement | null;
  if (btn) {
    btn.addEventListener("click", () => {
      if (typeof gtag !== "undefined") {
        gtag("event", "whatsapp_click_floating", { page_url: window.location.href });
      }
    });

    // Keep float above cookie banner while banner is visible
    const banner = document.getElementById("cookie-banner");
    if (banner) {
      const adjust = () => {
        btn.style.bottom = banner.isConnected ? `${banner.offsetHeight + 12}px` : "";
      };
      adjust();
      new MutationObserver(adjust).observe(document.body, { childList: true, subtree: false });
    }

    // Hide when footer enters viewport so it doesn't overlap legal links
    const footer = document.querySelector("footer");
    if (footer) {
      new IntersectionObserver(
        ([entry]) => {
          btn.style.opacity = entry.isIntersecting ? "0" : "";
          btn.style.pointerEvents = entry.isIntersecting ? "none" : "";
        },
        { threshold: 0.1 }
      ).observe(footer);
    }
  }
</script>

<style>
  .wa-float {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 40;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--ink);
    color: var(--bone);
    padding: 0.7rem 0.95rem;
    border: 1px solid var(--ink);
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    box-shadow: 0 12px 28px rgba(14, 14, 12, 0.18);
    transition: transform 200ms var(--ease-out), background 160ms var(--ease-out), border-color 160ms var(--ease-out), opacity 200ms var(--ease-out);
    text-decoration: none;
  }
  .wa-float:hover {
    background: var(--vermilion);
    border-color: var(--vermilion);
    transform: translateY(-2px);
  }
  .wa-float:focus-visible { outline: 2px solid var(--focus-ring); outline-offset: 3px; }

  .wa-float .dot {
    width: 8px;
    height: 8px;
    background: var(--color-wa);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .wa-float svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
    flex: 0 0 auto;
  }

  @media (max-width: 520px) {
    .wa-float .lbl { display: none; }
    .wa-float { padding: 0.85rem; }
  }
</style>
