---
interface Props {
  included: string[];
  excluded: string[];
  extras: string[];
}

const { included, excluded, extras } = Astro.props;
---

<section class="section scope-section" id="alcance" aria-labelledby="inc-h2">
  <div class="wrap">
    <h2 id="inc-h2" data-reveal>Qué incluye y qué no.</h2>
    <p class="lede" data-reveal="fade">
      Un alcance acotado es lo que permite ejecutar cada pieza bien. Aquí está todo lo que incluye el fee mensual, y lo
      que no, para que no haya sorpresas.
    </p>

    <div class="scope-section__grid">
      <div class="scope-section__col scope-section__col--included" data-reveal="slide">
        <p class="scope-section__col-label">Sí incluye</p>
        <ul class="scope-section__list" role="list">
          {
            included.map((item) => (
              <li>
                <span class="scope-section__list-mark" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path
                      d="M2 7l4 4 6-6"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="scope-section__col scope-section__col--excluded" data-reveal="slide">
        <p class="scope-section__col-label">No incluye</p>
        <ul class="scope-section__list" role="list">
          {
            excluded.map((item) => (
              <li>
                <span class="scope-section__list-mark" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M3 7h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                  </svg>
                </span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    {
      extras.length > 0 && (
        <div class="scope-section__extras" data-reveal="fade">
          <p class="scope-section__extras-label">Servicios opcionales</p>
          <ul class="scope-section__extras-list" role="list">
            {extras.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      )
    }

    <p class="note scope-section__note">
      La pauta publicitaria siempre va aparte. El cliente la paga directamente a Google. Nunca la incluimos en el fee.
      Así mantenemos las cuentas en manos del cliente y sin opacidad.
    </p>
  </div>
</section>
