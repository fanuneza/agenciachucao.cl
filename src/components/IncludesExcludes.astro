---
interface Props {
  included: string[];
  excluded: string[];
  extras: string[];
}

const { included, excluded, extras } = Astro.props;
---

<section class="section includes" id="alcance" aria-labelledby="inc-h2">
  <div class="wrap">
    <div class="tray">
      <span class="serial">§ 04 / Alcance</span>
      <span class="meta">Lo que incluye y lo que no</span>
    </div>

    <h2 id="inc-h2">Qué incluye y qué no.</h2>
    <p class="lede" style="margin-top:1.5rem;">
      Un alcance acotado es lo que permite ejecutar cada pieza bien. Aquí está todo lo que incluye el fee mensual, y lo
      que no, para que no haya sorpresas.
    </p>

    <div class="includes-grid">
      <div class="inc-col in">
        <p class="label">Sí incluye</p>
        <ul class="inc-list" role="list">
          {
            included.map((item) => (
              <li>
                <span class="mark" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path
                      d="M2 7l4 4 6-6"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                </span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="inc-col out">
        <p class="label">No incluye</p>
        <ul class="inc-list" role="list">
          {
            excluded.map((item) => (
              <li>
                <span class="mark" aria-hidden="true">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                    <path d="M3 7h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                  </svg>
                </span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    {
      extras.length > 0 && (
        <div class="extras-block">
          <p class="extras-label">Servicios opcionales</p>
          <ul class="extras-list" role="list">
            {extras.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      )
    }

    <p class="note includes-note">
      La pauta publicitaria siempre va aparte. El cliente la paga directamente a Google. Nunca la incluimos en el fee.
      Así mantenemos las cuentas en manos del cliente y sin opacidad.
    </p>
  </div>
</section>

<style>
  .includes-grid {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border: 1px solid var(--bone-line);
  }
  @media (min-width: 900px) {
    .includes-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .inc-col {
    padding: clamp(1.5rem, 2.5vw, 2.25rem);
  }
  .inc-col + .inc-col {
    border-top: 1px solid var(--bone-line);
  }
  @media (min-width: 900px) {
    .inc-col + .inc-col {
      border-top: 0;
      border-left: 1px solid var(--bone-line);
    }
  }

  .inc-col .label {
    font-family: var(--f-display);
    font-size: var(--t-lg);
    font-weight: 600;
    letter-spacing: -0.01em;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding-bottom: 1rem;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--bone-line);
    width: 100%;
  }
  .inc-col.in .label {
    color: var(--ink);
  }
  .inc-col.in .label::before {
    content: "";
    width: 8px;
    height: 8px;
    background: var(--vermilion);
    display: inline-block;
    border-radius: 50%;
  }
  .inc-col.out .label {
    color: var(--muted);
  }
  .inc-col.out .label::before {
    content: "";
    width: 8px;
    height: 8px;
    border: 1.5px solid var(--muted);
    display: inline-block;
    border-radius: 50%;
  }

  .inc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
  }
  .inc-list li {
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--bone-line);
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 0.85rem;
    font-size: var(--t-md);
    line-height: 1.5;
    align-items: start;
  }
  .inc-list li:last-child {
    border-bottom: 0;
  }
  .inc-col.out .inc-list li {
    color: var(--muted);
  }

  .inc-list .mark {
    color: var(--vermilion);
    margin-top: 0.15em;
    display: inline-flex;
  }
  .inc-col.out .inc-list li .mark {
    color: var(--muted);
  }

  .extras-block {
    margin-top: clamp(2rem, 3vw, 2.5rem);
    padding: clamp(1.25rem, 2vw, 1.75rem);
    border: 1px solid var(--bone-line);
    background: var(--bone-2);
  }

  .extras-label {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--graphite);
    margin: 0 0 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--bone-line);
  }

  .extras-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }
  @media (min-width: 640px) {
    .extras-list {
      grid-template-columns: 1fr 1fr;
    }
  }
  .extras-list li {
    font-size: var(--t-sm);
    color: var(--graphite);
    line-height: 1.5;
    padding-left: 1rem;
    position: relative;
  }
  .extras-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 1px;
    background: var(--muted);
  }

  .includes-note {
    margin-top: 1.5rem;
    max-width: 70ch;
  }
</style>
