---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
}

const { items } = Astro.props;
---

<section class="section faq" id="faq" aria-labelledby="faq-h2">
  <div class="wrap">
    <div class="tray">
      <span class="serial">§ 07 / Preguntas</span>
      <span class="meta">Las dudas que no quieres llevar a la llamada</span>
    </div>

    <h2 id="faq-h2">Las dudas que no<br />quieres llevar a la <em>llamada</em>.</h2>

    <div class="faq-list" role="list">
      {
        items.map((item, i) => (
          <div class="faq-item" role="listitem">
            <button class="faq-q" aria-expanded="false" aria-controls={`a${i}`} id={`q${i}`}>
              <span>
                <span class="ord">Q · {String(i + 1).padStart(2, "0")}</span>
                {item.question}
              </span>
              <span class="ind" aria-hidden="true" />
            </button>
            <div class="faq-a" id={`a${i}`} role="region" aria-labelledby={`q${i}`}>
              <div>
                <div class="faq-a-inner">{item.answer}</div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>(".faq-q").forEach((btn) => {
    btn.addEventListener("click", () => {
      const open = btn.getAttribute("aria-expanded") === "true";
      document.querySelectorAll(".faq-q").forEach((b) => b.setAttribute("aria-expanded", "false"));
      btn.setAttribute("aria-expanded", open ? "false" : "true");
    });
  });
</script>

<style>
  .faq-list {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--bone-line);
  }
  .faq-item {
    border-bottom: 1px solid var(--bone-line);
  }

  .faq-q {
    width: 100%;
    text-align: left;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0;
    font-family: var(--f-display);
    font-size: clamp(1.05rem, 0.6vw + 0.95rem, 1.35rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--ink);
    cursor: pointer;
  }
  .faq-q:hover {
    color: var(--vermilion);
  }
  .faq-q:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 4px;
  }

  .faq-q .ord {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    color: var(--vermilion);
    letter-spacing: 0.08em;
    margin-right: 1rem;
  }

  .faq-q .ind {
    width: 28px;
    height: 28px;
    display: inline-grid;
    place-items: center;
    border: 1px solid var(--bone-line);
    position: relative;
    flex: 0 0 auto;
    transition:
      border-color 160ms var(--ease-out),
      background 160ms var(--ease-out);
  }
  .faq-q[aria-expanded="true"] .ind {
    background: var(--ink);
    border-color: var(--ink);
  }

  .faq-q .ind::before,
  .faq-q .ind::after {
    content: "";
    position: absolute;
    background: var(--ink);
  }
  .faq-q .ind::before {
    width: 12px;
    height: 1.5px;
  }
  .faq-q .ind::after {
    width: 1.5px;
    height: 12px;
    transition: transform 200ms var(--ease-out);
  }
  .faq-q[aria-expanded="true"] .ind::before {
    background: var(--bone);
  }
  .faq-q[aria-expanded="true"] .ind::after {
    background: var(--bone);
    transform: scaleY(0);
  }

  .faq-a {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 220ms var(--ease-out);
  }
  .faq-a > div {
    overflow: hidden;
  }
  .faq-a-inner {
    padding: 0 0 1.5rem 0;
    max-width: 70ch;
    color: var(--graphite);
    font-size: var(--t-md);
    line-height: 1.6;
  }
  .faq-q[aria-expanded="true"] + .faq-a {
    grid-template-rows: 1fr;
  }
</style>
