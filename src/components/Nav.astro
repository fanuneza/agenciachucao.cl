---
---

<header class="nav-header">
  <div class="container nav-inner">
    <!-- Wordmark -->
    <a href="/" class="wordmark" aria-label="Agencia Chucao — inicio">
      <img
        src="/images/assets/chucao-logo.svg"
        alt=""
        aria-hidden="true"
        class="wordmark-logo"
        width="28"
        height="28"
      />
      <span class="wordmark-name"
        ><span class="wordmark-light">agencia</span><span class="wordmark-bold">chucao</span></span
      >
    </a>

    <!-- Desktop nav -->
    <nav class="nav-links" aria-label="Navegación principal">
      <a href="/contacto/" class="btn-primary nav-cta">Solicitar auditoría</a>
    </nav>

    <!-- Mobile hamburger -->
    <button class="hamburger" id="nav-toggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-drawer">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div class="nav-drawer" id="nav-drawer" aria-hidden="true">
    <nav class="drawer-links" aria-label="Menú móvil">
      <a href="/contacto/" class="btn-primary drawer-cta">Solicitar auditoría</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const drawer = document.getElementById("nav-drawer");

  toggle?.addEventListener("click", () => {
    const isOpen = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!isOpen));
    toggle.setAttribute("aria-label", isOpen ? "Abrir menú" : "Cerrar menú");
    drawer?.setAttribute("aria-hidden", String(isOpen));
    drawer?.classList.toggle("open", !isOpen);
    toggle.classList.toggle("open", !isOpen);
  });

  drawer?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      toggle?.setAttribute("aria-expanded", "false");
      drawer.setAttribute("aria-hidden", "true");
      drawer.classList.remove("open");
      toggle?.classList.remove("open");
    });
  });
</script>

<style>
  .nav-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--color-forest);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  /* Wordmark */
  .wordmark {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .wordmark-logo {
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    display: block;
  }
  .wordmark-name {
    display: inline;
  }
  .wordmark-light {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 18px;
    color: rgba(255, 255, 255, 0.75);
  }
  .wordmark-bold {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 18px;
    color: var(--color-orange);
  }

  /* Desktop nav */
  .nav-links {
    display: none;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-cta {
    font-size: 12px;
    padding: 0.625rem 1.25rem;
  }

  /* Hamburger */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.25rem;
    height: 2.25rem;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }
  @media (min-width: 1024px) {
    .hamburger {
      display: none;
    }
  }

  .hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 2px;
    transform-origin: center;
    transition:
      transform 0.25s var(--ease-spring),
      opacity 0.2s;
  }
  .hamburger.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger.open span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile drawer */
  .nav-drawer {
    display: none;
    background: var(--color-forest-mid);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }
  .nav-drawer.open {
    display: block;
  }
  @media (min-width: 1024px) {
    .nav-drawer {
      display: none !important;
    }
  }

  .drawer-links {
    display: flex;
    flex-direction: column;
    padding: 1rem var(--container-pad) 1.5rem;
  }

  .drawer-cta {
    text-align: center;
    justify-content: center;
  }
</style>
