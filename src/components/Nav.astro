---
import Brand from "@components/Brand.astro";
---

<header class="site-nav">
  <div class="wrap site-nav__inner">
    <Brand />

    <div class="site-nav__meta" aria-hidden="false">
      <span class="site-nav__meta-item">Santiago, Chile · clínicas dentales</span>
    </div>

    <a href="/contacto/" class="btn site-nav__cta" aria-label="Solicita una revisión gratis">
      <span class="site-nav__cta-label site-nav__cta-label--full">Solicita una revisión gratis</span>
      <span class="site-nav__cta-label site-nav__cta-label--short" aria-hidden="true">Auditoría gratis</span>
      <svg class="arrow" aria-hidden="true"><use href="#i-arrow"></use></svg>
    </a>
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 30;
    background: rgba(242, 238, 230, 0.92);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--bone-line);
  }
  .site-nav--scrolled {
    box-shadow: 0 1px 0 rgba(14, 14, 12, 0.06);
  }

  .site-nav__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    height: 64px;
  }

  .site-nav__meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    justify-content: center;
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    color: var(--muted);
    letter-spacing: 0.04em;
  }
  .site-nav__meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  @media (max-width: 880px) {
    .site-nav__meta {
      display: none;
    }
  }

  .site-nav__cta {
    padding: 0.6rem 0.95rem;
    min-height: 40px;
    font-size: var(--t-sm);
    white-space: nowrap;
  }

  .site-nav__cta-label--short {
    display: none;
  }
  @media (max-width: 520px) {
    .site-nav__cta-label--full {
      display: none;
    }
    .site-nav__cta-label--short {
      display: inline;
    }
  }
</style>
