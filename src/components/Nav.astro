---

---

<header class="nav">
  <div class="wrap nav-inner">
    <a href="/" class="brand" aria-label="Agencia Chucao - inicio">
      <svg class="mark" aria-hidden="true" style="color: var(--ink)"><use href="#chucao-mark"></use></svg>
      <span><span class="light">agencia</span><span class="bold">chucao</span></span>
    </a>

    <div class="nav-meta" aria-hidden="false">
      <span class="nav-meta-item">Clínicas dentales · Santiago</span>
    </div>

    <a href="/contacto/" class="btn nav-cta">
      Solicita una revisión gratis <svg class="arrow" aria-hidden="true"><use href="#i-arrow"></use></svg>
    </a>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 30;
    background: rgba(242, 238, 230, 0.92);
    backdrop-filter: saturate(140%) blur(10px);
    -webkit-backdrop-filter: saturate(140%) blur(10px);
    border-bottom: 1px solid var(--bone-line);
  }

  .nav-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    height: 64px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: var(--f-display);
    font-size: 0.95rem;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }
  .brand .mark {
    width: 22px;
    height: 22px;
  }
  .brand .light {
    font-weight: 400;
    color: var(--graphite);
  }
  .brand .bold {
    font-weight: 700;
    color: var(--ink);
  }
  .brand:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 4px;
  }

  .nav-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    justify-content: center;
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    color: var(--muted);
    letter-spacing: 0.04em;
  }
  .nav-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  @media (max-width: 880px) {
    .nav-meta {
      display: none;
    }
  }

  .nav-cta {
    padding: 0.6rem 0.95rem;
    min-height: 40px;
    font-size: var(--t-sm);
    white-space: nowrap;
  }
</style>
