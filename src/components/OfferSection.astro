---
import type { OfferComponent } from "../data/services";

interface Props {
  components: OfferComponent[];
}

const { components } = Astro.props;
---

<section class="section dark" id="oferta" aria-labelledby="offer-h2">
  <div class="wrap">
    <div class="tray">
      <span class="serial">Sistema</span>
      <span class="meta">Seis piezas, un objetivo</span>
    </div>

    <h2 id="offer-h2">El sistema de agendamientos.</h2>
    <p class="lede offer-section__lede">
      Un sistema de captación, conversión y medición con un solo objetivo: llenar la agenda de tu clínica. En 30 días
      tienes tres números concretos: costo por lead, costo por evaluación y costo por tratamiento.
    </p>

    <div class="offer-section__grid">
      {
        components.map((item) => (
          <article class="offer-section__item">
            <p class="offer-section__item-index">{item.idx}</p>
            <h3>{item.label}</h3>
            <p>{item.description}</p>
          </article>
        ))
      }
    </div>

    <p class="offer-section__promise">
      Menos fuga. Más pacientes agendados calificados. Con el costo de cada uno visible desde el día 30.
    </p>
  </div>
</section>

<style>
  .offer-section__lede {
    margin-top: 1.5rem;
  }

  .offer-section__grid {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: 1fr;
    border: 1px solid var(--ink-line);
    position: relative;
  }
  @media (min-width: 720px) {
    .offer-section__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1080px) {
    .offer-section__grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .offer-section__grid::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--vermilion) 0%, var(--vermilion) 60%, transparent 100%);
    opacity: 0.3;
    z-index: 1;
  }

  .offer-section__item {
    padding: clamp(1.5rem, 2.5vw, 2.25rem);
    border-right: 1px solid var(--ink-line);
    border-bottom: 1px solid var(--ink-line);
    display: grid;
    gap: 0.85rem;
    align-content: start;
    background: var(--ink);
    transition: background 160ms var(--ease-out);
    position: relative;
  }
  .offer-section__item:hover {
    background: var(--ink-2);
  }

  .offer-section__item-index {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    color: var(--vermilion-light);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 0;
  }
  .offer-section__item h3 {
    font-size: var(--t-xl);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--bone);
    line-height: 1.25;
  }
  .offer-section__item p:last-child {
    color: var(--muted-dark);
    font-size: var(--t-md);
    line-height: 1.6;
    margin: 0;
  }

  @media (min-width: 1080px) {
    .offer-section__item:nth-child(3n) {
      border-right: 0;
    }
    .offer-section__item:nth-last-child(-n + 3) {
      border-bottom: 0;
    }
  }
  @media (min-width: 720px) and (max-width: 1079px) {
    .offer-section__item:nth-child(2n) {
      border-right: 0;
    }
    .offer-section__item:nth-last-child(-n + 2) {
      border-bottom: 0;
    }
  }
  @media (max-width: 719px) {
    .offer-section__item {
      border-right: 0;
    }
    .offer-section__item:last-child {
      border-bottom: 0;
    }
  }

  .offer-section__promise {
    margin-top: clamp(2rem, 4vw, 3rem);
    font-family: var(--f-display);
    font-size: var(--t-2xl);
    line-height: 1.45;
    color: var(--bone);
    max-width: 62ch;
    border-top: 2px solid var(--vermilion);
    padding-left: 0;
    padding-top: 1.25rem;
  }
</style>
