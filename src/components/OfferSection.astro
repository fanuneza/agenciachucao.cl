---
import type { OfferComponent } from "../data/services";

interface Props {
  components: OfferComponent[];
}

const { components } = Astro.props;
---

<section class="offer section-pad">
  <div class="container">
    <p class="section-label section-label-light offer-reveal">El sistema</p>
    <h2 class="offer-h2 offer-reveal">El Lead Engine dental.</h2>

    <p class="offer-intro offer-reveal">
      No es una lista de servicios. Es un sistema de captación, conversión y medición diseñado para una sola cosa:
      convertir demanda existente en evaluaciones agendadas. En 30 días tienes tres números visibles: costo por lead,
      costo por evaluación y costo por tratamiento.
    </p>

    <ul class="offer-grid offer-reveal" role="list">
      {
        components.map((item) => (
          <li class="offer-card">
            <p class="offer-card-label">{item.label}</p>
            <p class="offer-card-desc">{item.description}</p>
          </li>
        ))
      }
    </ul>

    <p class="offer-promise offer-reveal">
      La promesa no es "más leads". Es menos fuga y más evaluaciones calificadas, con el costo de cada una visible
      desde el día 30.
    </p>
  </div>
</section>

<style>
  .offer {
    background: var(--color-forest);
    color: var(--color-white);
  }

  .offer-h2 {
    font-size: var(--text-h2-size);
    font-weight: var(--text-h2-weight);
    letter-spacing: var(--text-h2-track);
    line-height: var(--text-h2-leading);
    color: var(--color-white);
    margin-block: 0 1.5rem;
  }

  .offer-intro {
    font-family: var(--font-serif);
    font-size: var(--text-lede-size);
    line-height: var(--text-lede-leading);
    color: rgba(255, 255, 255, 0.65);
    max-width: 58ch;
    margin-bottom: 3.5rem;
  }

  .offer-grid {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 3.5rem;
  }
  @media (min-width: 640px) {
    .offer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .offer-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .offer-card {
    background: rgba(255, 255, 255, 0.03);
    padding: 2rem 1.75rem;
    transition: background 0.2s;
  }
  .offer-card:hover {
    background: rgba(255, 255, 255, 0.07);
  }

  .offer-card-label {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.05em;
    color: var(--color-orange);
    margin-bottom: 0.875rem;
    text-transform: uppercase;
  }

  .offer-card-desc {
    font-family: var(--font-serif);
    font-size: var(--text-body-size);
    line-height: var(--text-body-leading);
    color: rgba(255, 255, 255, 0.6);
  }

  .offer-promise {
    font-family: var(--font-serif);
    font-size: clamp(16px, 1.8vw, 18px);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.5);
    border-left: 3px solid var(--color-orange);
    padding-left: 1.5rem;
    max-width: 56ch;
  }
</style>
