---
interface Step {
  number: string;
  title: string;
  timeline: string;
  description: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<section class="section process-section" id="proceso" aria-labelledby="how-h2">
  <div class="wrap">
    <h2 id="how-h2" data-reveal>Qué pasa después de que firmas.</h2>
    <p class="lede process-section__lede" data-reveal="fade">
      El primer mes se usa para instalar el sistema, activar tráfico medible y detectar qué tan bien convierte la
      clínica desde Google hasta WhatsApp.
    </p>

    <ol class="process-timeline" role="list" data-reveal-group>
      {
        steps.map((step) => (
          <li class="process-timeline__step" data-reveal>
            <span class="process-timeline__marker" aria-hidden="true">
              <span class="process-timeline__num">{step.number}</span>
            </span>
            <p class="process-timeline__when">{step.timeline}</p>
            <p class="process-timeline__title">{step.title}</p>
            <p class="process-timeline__desc">{step.description}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
