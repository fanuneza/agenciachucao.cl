---
interface Step {
  number: string;
  title: string;
  timeline: string;
  description: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<section class="section process-section" id="proceso" aria-labelledby="how-h2">
  <div class="wrap">
    <div class="tray">
      <span class="serial">Procedimiento</span>
      <span class="meta">De la instalación a la medición mensual</span>
    </div>

    <h2 id="how-h2">Qué pasa después de que firmas.</h2>
    <p class="lede process-section__lede">
      El primer mes se usa para instalar el sistema, activar tráfico medible y detectar qué tan bien convierte la
      clínica desde Google hasta WhatsApp.
    </p>

    <ol class="process-section__steps" role="list">
      {
        steps.map((step) => (
          <li class="process-section__step">
            <div class="process-section__step-header">
              <span class="process-section__step-num">{step.number}</span>
              <span class="process-section__step-timeline">{step.timeline}</span>
            </div>
            <p class="process-section__step-title">{step.title}</p>
            <p class="process-section__step-desc">{step.description}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
