---
interface Step {
  number: string;
  title: string;
  timeline: string;
  description: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<section class="section how" id="proceso" aria-labelledby="how-h2">
  <div class="wrap">
    <div class="tray">
      <span class="serial">§ 03 / Procedimiento</span>
      <span class="meta">Primer mes de trabajo</span>
    </div>

    <h2 id="how-h2">Qué pasa después de que firmas.</h2>
    <p class="lede how-lede">
      El primer mes se usa para instalar el sistema, activar tráfico medible y detectar qué tan bien convierte la
      clínica desde Google hasta WhatsApp.
    </p>

    <ol class="steps" role="list">
      {
        steps.map((step) => (
          <li class="step">
            <div class="step-header">
              <span class="num">{step.number}</span>
              <span class="timeline">{step.timeline}</span>
            </div>
            <p class="title">{step.title}</p>
            <p class="desc">{step.description}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .how-lede {
    margin-top: 1.5rem;
  }

  .steps {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border: 1px solid var(--bone-line);
    list-style: none;
    padding: 0;
  }
  @media (min-width: 720px) {
    .steps {
      grid-template-columns: 1fr 1fr;
    }
  }

  .step {
    padding: clamp(1.5rem, 2.5vw, 2.25rem);
    border-bottom: 1px solid var(--bone-line);
    border-right: 1px solid var(--bone-line);
    display: grid;
    gap: 0.75rem;
    align-content: start;
  }
  @media (min-width: 720px) {
    .step:nth-child(2n) {
      border-right: 0;
    }
    .step:nth-last-child(-n + 2) {
      border-bottom: 0;
    }
  }
  @media (max-width: 719px) {
    .step {
      border-right: 0;
    }
    .step:last-child {
      border-bottom: 0;
    }
  }

  .step-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .step .num {
    font-family: var(--f-display);
    font-size: clamp(2rem, 3vw, 2.75rem);
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.04em;
    line-height: 1;
  }

  .step .timeline {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    color: var(--vermilion);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .step .title {
    font-family: var(--f-display);
    font-size: var(--t-xl);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.25;
    margin: 0;
  }

  .step .desc {
    color: var(--graphite);
    font-size: var(--t-md);
    line-height: 1.6;
    margin: 0;
    max-width: 50ch;
  }
</style>
