---
interface Step {
  number: string;
  title: string;
  timeline: string;
  description: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<section class="section how" id="proceso" aria-labelledby="how-h2">
  <div class="wrap">
    <div class="tray">
      <span class="serial">§ 03 / Procedimiento</span>
      <span class="meta">45 días · cuatro fases</span>
    </div>

    <h2 id="how-h2">Qué pasa después<br/>de que <em>firmas</em>.</h2>

    <ol class="steps" role="list">
      {steps.map((step) => (
        <li class="step">
          <span class="num">{step.number}</span>
          <div class="body">
            <span class="timeline">{step.timeline}</span>
            <p class="title">{step.title}</p>
            <p class="desc">{step.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .steps {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    display: grid;
    gap: 0;
    border-top: 1px solid var(--bone-line);
    list-style: none;
    padding: 0;
  }

  .step {
    display: grid;
    grid-template-columns: 90px 1fr;
    gap: clamp(1rem, 2vw, 2rem);
    padding: clamp(1.5rem, 3vw, 2.25rem) 0;
    border-bottom: 1px solid var(--bone-line);
    align-items: baseline;
  }
  @media (min-width: 720px) {
    .step { grid-template-columns: 90px 180px 1fr; }
  }
  @media (max-width: 480px) {
    .step { grid-template-columns: 1fr; gap: 0.5rem; }
  }

  .step .num {
    font-family: var(--f-display);
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.04em;
  }

  .step .body { display: grid; gap: 0.5rem; }

  .step .timeline {
    font-family: var(--f-mono);
    font-size: var(--t-xs);
    color: var(--vermilion);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }
  .step .title {
    font-family: var(--f-display);
    font-size: var(--t-xl);
    font-weight: 600;
    letter-spacing: -0.015em;
    margin: 0;
  }
  .step .desc {
    color: var(--graphite);
    max-width: 56ch;
    margin: 0;
  }
</style>
