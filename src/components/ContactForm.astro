---
import { buildWhatsAppUrl } from "@/utils/whatsapp";

const waNumber = import.meta.env.PUBLIC_WA_NUMBER;
const waFallbackMessage = "Hola, intenté contactarme por el formulario pero tuve un problema. ¿Podrían ayudarme?";
const waFallback = buildWhatsAppUrl(waNumber, waFallbackMessage);
const web3Key = import.meta.env.PUBLIC_WEB3FORMS_KEY;
---

<form class="contact-form" id="contact-form" novalidate>
  <input type="hidden" name="access_key" value={web3Key} />
  <input type="text" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

  <div class="contact-form__group">
    <label class="field-label" for="nombre">Tu nombre</label>
    <input
      class="form-field"
      type="text"
      id="nombre"
      name="nombre"
      autocomplete="name"
      placeholder="Nombre y apellido"
      required
    />
    <span class="contact-form__error" id="err-nombre"></span>
  </div>

  <div class="contact-form__group">
    <label class="field-label" for="clinica">Nombre de tu clínica</label>
    <input class="form-field" type="text" id="clinica" name="clinica" placeholder="Clínica Dental..." required />
    <span class="contact-form__error" id="err-clinica"></span>
  </div>

  <div class="contact-form__group">
    <label class="field-label" for="phone">Teléfono o WhatsApp</label>
    <input
      class="form-field"
      type="tel"
      id="phone"
      name="phone"
      autocomplete="tel"
      inputmode="tel"
      placeholder="+56 9 1234 5678"
      required
    />
    <span class="contact-form__error" id="err-phone"></span>
  </div>

  <div class="contact-form__group">
    <label class="field-label" for="tratamiento">Tratamiento principal</label>
    <select class="form-field contact-form__select" id="tratamiento" name="tratamiento" required>
      <option value="">Selecciona una opción…</option>
      <option value="Implantología">Implantología</option>
      <option value="Ortodoncia">Ortodoncia</option>
      <option value="Rehabilitación oral">Rehabilitación oral</option>
      <option value="Otro">Otro</option>
    </select>
    <span class="contact-form__error" id="err-tratamiento"></span>
  </div>

  <div id="form-status" class="contact-form__status" aria-live="polite"></div>

  <button type="submit" class="btn contact-form__submit" id="form-submit-btn" data-label="Solicita una revisión gratis"
    >Solicita una revisión gratis <svg class="arrow" aria-hidden="true"><use href="#i-arrow"></use></svg></button
  >
</form>

<div id="form-success" class="contact-form__success" hidden tabindex="-1">
  <p class="contact-form__success-title">Recibimos tu solicitud.</p>
  <p class="contact-form__success-text">Te contactamos en menos de 24 horas hábiles para revisar tu clínica.</p>
  <p class="contact-form__success-note">
    Si prefieres, <a href={waFallback} target="_blank" rel="noopener noreferrer" class="contact-form__fallback-link"
      >escríbenos por WhatsApp</a
    >.
  </p>
</div>

<div class="contact-form__fallback">
  <p class="contact-form__fallback-text">
    ¿Prefieres WhatsApp? <a
      href={waFallback}
      target="_blank"
      rel="noopener noreferrer"
      class="contact-form__fallback-link">Escríbenos directamente →</a
    >
  </p>
</div>
