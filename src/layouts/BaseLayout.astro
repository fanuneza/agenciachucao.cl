---
import Seo from "@jdevalk/astro-seo-graph/Seo.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import CookieConsent from "@components/CookieConsent.astro";
import IconSprite from "@components/IconSprite.astro";
import LazyStyles from "@components/LazyStyles.astro";
import "@styles/global.css";

import { buildSchemaGraph, type JsonLdGraph, type JsonLdNode } from "@/utils/schema";

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  schema?: JsonLdNode | JsonLdNode[] | JsonLdGraph;
}

const { title, description, image, canonical, noindex, schema } = Astro.props;
const siteUrl = "https://agenciachucao.cl";
const defaultOgImage = "/images/og/og-image.webp";
const ogImage = image || defaultOgImage;
const absoluteOgImage = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();

const isHome = Astro.url.pathname === "/" || Astro.url.pathname === "";
const defaultSchema = buildSchemaGraph({
  pageType: isHome ? "website" : "webpage",
  url: canonicalUrl,
  title,
  description,
  includeBreadcrumbs: !isHome && !noindex,
});

let finalSchema = defaultSchema;
if (schema) {
  if ("@graph" in schema && Array.isArray(schema["@graph"])) {
    finalSchema = schema as JsonLdGraph;
  } else {
    const node = { ...schema };
    delete (node as any)["@context"];
    finalSchema["@graph"].push(node);
  }
}
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <Seo
      title={title}
      titleTemplate="%s | Agencia Chucao"
      description={description}
      canonical={canonicalUrl}
      noindex={noindex}
      ogType="website"
      ogImage={absoluteOgImage}
      ogImageAlt={title}
      ogImageWidth={1200}
      ogImageHeight={630}
      siteName="Agencia Chucao"
      locale="es_CL"
      graph={finalSchema}
      twitter={{ card: "summary_large_image" }}
      extraLinks={[
        { rel: "icon", type: "image/x-icon", href: "/favicon.ico" },
        { rel: "sitemap", type: "application/xml", href: "/sitemap-index.xml" },
      ]}
    />

    <meta name="theme-color" content="#0e0e0c" />
    {
      isHome && (
        <link
          rel="preload"
          as="image"
          href="https://images.unsplash.com/photo-1629909615957-be38d48fbbe6?auto=format&fit=crop&w=1600&q=80"
          imagesrcset="https://images.unsplash.com/photo-1629909615957-be38d48fbbe6?auto=format&fit=crop&w=800&q=80 800w, https://images.unsplash.com/photo-1629909615957-be38d48fbbe6?auto=format&fit=crop&w=1600&q=80 1600w"
          imagesizes="100vw"
        />
      )
    }
    <script src="../scripts/site.ts"></script>
    <slot name="head" />
  </head>
  <body>
    <IconSprite />
    <a class="skip-link" href="#main">Saltar al contenido</a>

    <Nav />

    <main id="main">
      <slot />
    </main>

    <Footer />
    <CookieConsent />
    <LazyStyles
      targets={[
        { selector: ".site-footer", href: "/styles/footer.css" },
        { selector: ".cookie-banner", href: "/styles/cookie-banner.css" },
      ]}
    />
  </body>
</html>
