---
import Seo from "@jdevalk/astro-seo-graph/Seo.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import CookieConsent from "@components/CookieConsent.astro";
import IconSprite from "@components/IconSprite.astro";
import type { JsonLdGraph, JsonLdNode } from "@/lib/structured-data";
import "@styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  schema?: JsonLdNode | JsonLdNode[] | JsonLdGraph;
}

const { title, description, image, canonical, noindex, schema } = Astro.props;
const siteUrl = "https://agenciachucao.cl";
const defaultOgImage = "/images/og/og-image.webp";
const ogImage = image || defaultOgImage;
const absoluteOgImage = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <Seo
      title={title}
      titleTemplate="%s | Agencia Chucao"
      description={description}
      canonical={canonicalUrl}
      noindex={noindex}
      ogType="website"
      ogImage={absoluteOgImage}
      ogImageAlt={title}
      ogImageWidth={1200}
      ogImageHeight={630}
      siteName="Agencia Chucao"
      locale="es_CL"
      graph={schema as any}
      extraLinks={[
        { rel: "icon", type: "image/x-icon", href: "/favicon.ico" },
        { rel: "sitemap", type: "application/xml", href: "/sitemap-index.xml" },
      ]}
    />

    <meta name="theme-color" content="#0A0A0A" />
    <script src="../scripts/site.ts"></script>
  </head>
  <body>
    <IconSprite />
    <a class="skip-link" href="#main">Saltar al contenido</a>

    <Nav />

    <main id="main">
      <slot />
    </main>

    <Footer />
    <CookieConsent />
  </body>
</html>
