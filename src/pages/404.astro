---
import BaseLayout from "@layouts/BaseLayout.astro";
import FuzzyRedirect from "@jdevalk/astro-seo-graph/FuzzyRedirect.astro";
import { buildWhatsAppUrl } from "@/utils/whatsapp";

const waNumber = import.meta.env.PUBLIC_WA_NUMBER;
const waMessage = "Hola, llegué a una página que no existe en Agencia Chucao. ¿Me pueden ayudar?";
const waHref = buildWhatsAppUrl(waNumber, waMessage);
---

<BaseLayout
  title="Página no encontrada"
  description="Esta página no existe o fue movida. Vuelve al inicio o escríbenos por WhatsApp."
  noindex={true}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/styles/base-content.css" />
    <link rel="stylesheet" href="/styles/not-found.css" />
  </Fragment>

  <section class="section dark not-found" aria-labelledby="not-found-title">
    <div class="wrap not-found__inner">
      <span class="not-found__code" aria-hidden="true">404</span>
      <h1 id="not-found-title" class="not-found__title">Esta página no existe</h1>
      <p class="not-found__text">
        Puede que haya sido movida, eliminada o que la URL tenga un error. No te preocupes — desde aquí puedes volver al
        inicio o escribirnos directamente.
      </p>
      <div class="not-found__redirect">
        <FuzzyRedirect />
      </div>
      <div class="not-found__actions">
        <a href="/" class="btn">Volver al inicio</a>
        <a href={waHref} target="_blank" rel="noopener noreferrer" class="btn btn-secondary not-found__wa">
          Escribir por WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
