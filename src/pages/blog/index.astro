---
import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import BlogCard from '@components/BlogCard.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);
---

<BaseLayout
  title="Blog — Marketing Digital para Negocios Chilenos"
  description="Artículos sobre SEO, redes sociales, desarrollo web y estrategia digital. Escritos por periodistas para negocios que quieren entender lo que están haciendo."
>
  <header class="blog-hero noise-bg">
    <div class="container blog-hero-inner">
      <p class="section-label section-label-light hero-anim-1">Blog</p>
      <h1 class="blog-h1 hero-anim-2">Marketing digital sin humo</h1>
      <p class="blog-lede hero-anim-3">
        Artículos escritos con criterio periodístico sobre SEO, redes sociales, desarrollo web y estrategia digital.
        Para negocios que quieren entender lo que están haciendo.
      </p>
    </div>
  </header>

  <section class="blog-body section-py">
    <div class="container">
      {posts.length > 0 ? (
        <div class="blog-grid">
          {posts.map((post) => <BlogCard post={post} />)}
        </div>
      ) : (
        <p class="blog-empty">Los artículos llegarán pronto.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    background: var(--color-forest);
    color: var(--color-white);
    padding-block: clamp(4rem, 8vw, 6rem);
  }
  .blog-hero-inner { max-width: 64ch; }

  .blog-h1 {
    font-size: clamp(40px, 5vw, 68px);
    font-weight: var(--text-h1-weight);
    letter-spacing: var(--text-h1-track);
    line-height: var(--text-h1-leading);
    color: var(--color-white);
    margin-block: 1.25rem 1rem;
  }

  .blog-lede {
    font-family: var(--font-serif);
    font-size: var(--text-lede-size);
    line-height: var(--text-lede-leading);
    color: rgba(255, 255, 255, 0.65);
    max-width: 54ch;
  }

  .blog-body { background: var(--color-sage); }

  .blog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) {
    .blog-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .blog-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .blog-empty {
    font-family: var(--font-serif);
    font-size: 17px;
    color: var(--color-olive);
    padding: 4rem 0;
  }
</style>
