---
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactForm from "@components/ContactForm.astro";
import WhatsAppButton from "@components/WhatsAppButton.astro";
---

<BaseLayout
  title="Solicita tu auditoría gratuita | Agencia Chucao"
  description="Cuéntanos de tu clínica. Revisamos dónde se están perdiendo evaluaciones y te mostramos cómo medirlo."
  canonical="https://agenciachucao.cl/contacto/"
>
  <section class="audit-hero noise-bg">
    <div class="container audit-hero-inner">
      <p class="section-label section-label-light hero-anim-1">Auditoría gratuita</p>
      <h1 class="audit-h1 hero-anim-2">Cuéntanos de tu clínica.</h1>
      <p class="audit-lede hero-anim-3">
        Revisamos dónde se están perdiendo evaluaciones y te mostramos cómo medirlo. Sin compromiso, sin presentación.
        Solo números.
      </p>
    </div>
  </section>

  <section class="audit-body">
    <div class="container audit-inner">
      <div class="audit-form-wrap">
        <ContactForm />
      </div>

      <aside class="audit-aside">
        <div class="aside-block">
          <p class="aside-label">Tiempo de respuesta</p>
          <p class="aside-text">Menos de 24 horas hábiles.</p>
        </div>

        <div class="aside-block">
          <p class="aside-label">Qué pasa después</p>
          <p class="aside-text">
            Revisamos tu sitio, tu perfil en Google y tu presencia en directorios. Te enviamos una auditoría breve con
            los puntos de fuga que encontramos. Sin cobrarte nada.
          </p>
        </div>

        <div class="aside-block">
          <p class="aside-label">Correo directo</p>
          <a href="mailto:contacto@agenciachucao.cl" class="aside-email">contacto@agenciachucao.cl</a>
        </div>
      </aside>
    </div>
  </section>

  <WhatsAppButton />
</BaseLayout>

<style>
  .audit-hero {
    background: var(--color-forest);
    color: var(--color-white);
    padding-top: clamp(2rem, 4vw, 3.5rem);
    padding-bottom: clamp(3.5rem, 6vw, 5.5rem);
  }
  .audit-hero-inner {
    max-width: 64ch;
  }
  .audit-h1 {
    font-size: var(--text-h1-size);
    font-weight: var(--text-h1-weight);
    letter-spacing: var(--text-h1-track);
    line-height: var(--text-h1-leading);
    color: var(--color-white);
    margin-block: 1.25rem 1rem;
  }
  .audit-lede {
    font-family: var(--font-serif);
    font-size: var(--text-lede-size);
    line-height: var(--text-lede-leading);
    color: rgba(255, 255, 255, 0.65);
    max-width: 54ch;
  }

  .audit-body {
    background: var(--color-sage);
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .audit-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .audit-inner {
      grid-template-columns: 1fr 280px;
    }
  }

  .audit-aside {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: sticky;
    top: 5.5rem;
  }

  .aside-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-moss);
  }
  .aside-block:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .aside-label {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-olive);
  }

  .aside-text {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.7;
    color: var(--color-olive);
  }

  .aside-email {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-forest);
    text-decoration: none;
    word-break: break-all;
    transition: color 0.15s;
  }
  .aside-email:hover {
    color: var(--color-orange);
  }
</style>
