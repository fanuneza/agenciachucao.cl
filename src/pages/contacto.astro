---
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactForm from "@components/ContactForm.astro";
import WhatsAppButton from "@components/WhatsAppButton.astro";
import LazyStyles from "@components/LazyStyles.astro";
---

<BaseLayout
  title="Solicita tu auditoría gratuita"
  description="Cuéntanos de tu clínica. Revisamos dónde se están perdiendo pacientes agendados y te mostramos cómo medirlo."
  canonical="https://agenciachucao.cl/contacto/"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/styles/audit-hero.css" />
  </Fragment>

  <section class="section dark audit-page__hero">
    <div class="wrap">
      <div class="tray">
        <span class="serial">Auditoría gratuita</span>
        <span class="meta">Sin compromiso · respuesta en 24 h</span>
      </div>
      <h1>Cuéntanos de<br />tu clínica.</h1>
      <p class="lede audit-page__lede">
        Revisamos dónde se están perdiendo pacientes agendados y te mostramos cómo medirlo. Sin compromiso, sin
        presentación. Solo números.
      </p>
    </div>
  </section>

  <section class="section audit-page__body">
    <div class="wrap">
      <div class="audit-page__grid">
        <div class="audit-page__form">
          <ContactForm />
        </div>

        <aside class="audit-page__aside">
          <div class="audit-page__block">
            <p class="kicker">Tiempo de respuesta</p>
            <p class="audit-page__block-text">
              Menos de 24 horas hábiles. Si es viernes en la tarde, respondemos el lunes temprano.
            </p>
          </div>
          <div class="audit-page__block">
            <p class="kicker">Qué pasa después</p>
            <p class="audit-page__block-text">
              Revisamos tu sitio, tu perfil en Google y tu presencia en directorios. Te enviamos una revisión breve con
              los puntos de fuga. Sin cobrarte nada.
            </p>
          </div>
          <div class="audit-page__block">
            <p class="kicker">Correo directo</p>
            <a href="mailto:contacto@agenciachucao.cl" class="audit-page__email">contacto@agenciachucao.cl</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <WhatsAppButton />
  <LazyStyles targets={[{ selector: ".contact-form", href: "/styles/contact-form.css" }]} />
</BaseLayout>
