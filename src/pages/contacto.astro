---
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactForm from "@components/ContactForm.astro";
import WhatsAppButton from "@components/WhatsAppButton.astro";
---

<BaseLayout
  title="Solicita tu auditoría gratuita"
  description="Cuéntanos de tu clínica. Revisamos dónde se están perdiendo pacientes agendados y te mostramos cómo medirlo."
  canonical="https://agenciachucao.cl/contacto/"
>
  <section class="section dark audit-page__hero">
    <div class="wrap">
      <div class="tray">
        <span class="serial">Auditoría gratuita</span>
        <span class="meta">Sin compromiso · respuesta en 24 h</span>
      </div>
      <h1>Cuéntanos de<br />tu clínica.</h1>
      <p class="lede audit-page__lede">
        Revisamos dónde se están perdiendo pacientes agendados y te mostramos cómo medirlo. Sin compromiso, sin
        presentación. Solo números.
      </p>
    </div>
  </section>

  <section class="section audit-page__body">
    <div class="wrap">
      <div class="audit-page__grid">
        <div class="audit-page__form">
          <ContactForm />
        </div>

        <aside class="audit-page__aside">
          <div class="audit-page__block">
            <p class="kicker">Tiempo de respuesta</p>
            <p class="audit-page__block-text">
              Menos de 24 horas hábiles. Si es viernes en la tarde, respondemos el lunes temprano.
            </p>
          </div>
          <div class="audit-page__block">
            <p class="kicker">Qué pasa después</p>
            <p class="audit-page__block-text">
              Revisamos tu sitio, tu perfil en Google y tu presencia en directorios. Te enviamos una auditoría breve con
              los puntos de fuga. Sin cobrarte nada.
            </p>
          </div>
          <div class="audit-page__block">
            <p class="kicker">Correo directo</p>
            <a href="mailto:contacto@agenciachucao.cl" class="audit-page__email">contacto@agenciachucao.cl</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <WhatsAppButton />
</BaseLayout>

<style>
  .audit-page__hero {
    border-top: 0;
  }
  .audit-page__lede {
    margin-top: 1.5rem;
  }

  .audit-page__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(3rem, 6vw, 5rem);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .audit-page__grid {
      grid-template-columns: minmax(0, 600px) 280px;
    }
  }

  .audit-page__aside {
    display: flex;
    flex-direction: column;
    gap: 0;
    position: sticky;
    top: 5.5rem;
  }

  .audit-page__block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-block: 1.5rem;
    border-bottom: 1px solid var(--bone-line);
  }
  .audit-page__block:first-child {
    padding-top: 0;
  }
  .audit-page__block:last-child {
    border-bottom: none;
  }

  .audit-page__block-text {
    font-size: var(--t-md);
    line-height: 1.65;
    color: var(--graphite);
    margin: 0;
  }

  .audit-page__email {
    font-family: var(--f-mono);
    font-size: var(--t-sm);
    color: var(--ink);
    word-break: break-all;
    transition: color 160ms var(--ease-out);
  }
  .audit-page__email:hover {
    color: var(--vermilion);
  }
</style>
