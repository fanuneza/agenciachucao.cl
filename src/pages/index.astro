---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import ProblemSection from "@components/ProblemSection.astro";
import OfferSection from "@components/OfferSection.astro";
import HowItWorks from "@components/HowItWorks.astro";
import ProofSection from "@components/ProofSection.astro";
import IncludesExcludes from "@components/IncludesExcludes.astro";
import QualificationSection from "@components/QualificationSection.astro";
import FoundingOffer from "@components/FoundingOffer.astro";
import FAQ from "@components/FAQ.astro";
import CTAFinal from "@components/CTAFinal.astro";
import WhatsAppButton from "@components/WhatsAppButton.astro";
import LazyStyles from "@components/LazyStyles.astro";
import { offerComponents } from "@data/services";
import { buildFaqPage } from "@/utils/schema";
import { buildWhatsAppUrl } from "@/utils/whatsapp";

const waNumber = import.meta.env.PUBLIC_WA_NUMBER;
const waMessage =
  "Hola, vi Agencia Chucao y me interesa el sistema de agendamientos para mi clínica dental. ¿Tienen disponibilidad?";
const waHref = buildWhatsAppUrl(waNumber, waMessage);

const howSteps = [
  {
    number: "01",
    title: "Instalación",
    timeline: "Semana 1",
    description:
      "Instalamos la landing, la estructura de campaña, los eventos de conversión y la conexión hacia WhatsApp.",
  },
  {
    number: "02",
    title: "Tráfico",
    timeline: "Días 7 a 14",
    description:
      "Activamos búsquedas con intención comercial y empezamos a separar consultas útiles de tráfico irrelevante.",
  },
  {
    number: "03",
    title: "Primeras consultas",
    timeline: "Primeros 30 días",
    description: "Revisamos volumen, calidad de consultas, respuesta por WhatsApp y fricciones antes del agendamiento.",
  },
  {
    number: "04",
    title: "Medición y ajustes",
    timeline: "Mensual",
    description: "Ajustamos palabras clave, anuncios, presupuesto, landing y seguimiento según datos reales.",
  },
];

const included = [
  "Instalación inicial de Google Ads",
  "Landing de conversión",
  "Integración con WhatsApp",
  "Medición básica de conversiones",
  "SEO local básico / Google Business Profile",
  "Reporte mensual",
  "Ajustes mensuales de campaña",
];

const excluded = [
  "Community management diario",
  "Producción audiovisual",
  "Respuesta manual de WhatsApp por parte del equipo",
  "Garantía de cantidad exacta de pacientes",
  "Gestión clínica interna",
  "Software CRM avanzado",
];

const extras = [
  "Nueva landing por tratamiento adicional",
  "Segunda sede",
  "Nueva categoría de tratamiento",
  "Integraciones técnicas adicionales",
  "Copy adicional",
  "Correcciones de sitio heredado fuera del embudo",
];

const faqItems = [
  {
    question: "¿Por qué un fee de $950.000 a $1.200.000 al mes si hay agencias más baratas?",
    answer:
      "Este no es community management. Incluye setup de campaña, landing de conversión, medición de conversiones, reporte mensual y optimización. Las primeras 2 clínicas entran con precio de cupo inicial ($950.000/mes); al cerrarse, el fee estándar es $1.150.000 a $1.200.000/mes. La pauta la pagas directo a Google, no pasa por nosotros. El objetivo es construir un sistema de adquisición medible, no solo correr anuncios.",
  },
  {
    question: "Ya tenemos agencia.",
    answer:
      "Podemos funcionar como una capa enfocada en adquisición dental sin reemplazar todo tu marketing. El sistema de agendamientos se encarga de la parte medible: búsquedas, landing, WhatsApp y reportes. Si tu agencia actual ya tiene eso claro, probablemente no necesitas esto.",
  },
  {
    question: "¿Cuánto demora en verse resultados?",
    answer:
      "El primer mes es para setup, lanzamiento y diagnóstico. La campaña necesita tráfico suficiente para aprender. Las primeras señales útiles aparecen cuando hay volumen y disciplina de seguimiento. No prometemos pacientes en una semana.",
  },
  {
    question: "¿Qué pasa si no funciona?",
    answer:
      "El primer diagnóstico es identificar dónde está el cuello de botella: si es tráfico, conversión de la landing, respuesta por WhatsApp, precio del tratamiento o economía del negocio. El sistema existe para localizar el problema en lugar de adivinar.",
  },
  {
    question: "¿Qué no incluye el fee?",
    answer:
      "Revisa la sección de alcance arriba. Lo esencial: no incluimos community management, producción de contenido, desarrollo web ni pauta publicitaria. La pauta la pagas directamente a Google. Tampoco garantizamos una cantidad específica de pacientes.",
  },
];

const faqSchema = buildFaqPage(faqItems);
---

<BaseLayout
  title="Agendamientos para clínicas dentales en Santiago"
  description="Convertimos búsquedas activas en pacientes agendados. Sistema de captación medible para implantología, ortodoncia y rehabilitación en Santiago. Sin contratos largos."
  schema={faqSchema}
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/styles/hero.css" />
  </Fragment>

  <Hero
    headline="Convierte búsquedas en agendamientos."
    subheadline="Google Ads + landing de conversión + seguimiento por WhatsApp para clínicas dentales en Santiago. En 30 días sabes cuánto te cuesta cada paciente nuevo."
    ctaText="Solicita una revisión gratis"
    ctaHref="/contacto/"
  />

  <ProblemSection />

  <OfferSection components={offerComponents} />

  <HowItWorks steps={howSteps} />

  <ProofSection />

  <IncludesExcludes included={included} excluded={excluded} extras={extras} />

  <QualificationSection />

  <FoundingOffer spotsTotal={2} ctaHref="/contacto/" />

  <FAQ items={faqItems} />

  <CTAFinal
    headline="Revisemos si tu clínica puede generar más agendamientos desde Google."
    ctaText="Solicita una revisión gratis"
    ctaHref="/contacto/"
    whatsappHref={waHref}
  />

  <WhatsAppButton />
  <LazyStyles
    targets={[
      { selector: ".problem-section", href: "/styles/home-sections.css" },
      { selector: ".problem-section", href: "/styles/base-content.css" },
    ]}
  />
</BaseLayout>
