---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import ProblemSection from "@components/ProblemSection.astro";
import OfferSection from "@components/OfferSection.astro";
import HowItWorks from "@components/HowItWorks.astro";
import IncludesExcludes from "@components/IncludesExcludes.astro";
import PricingSection from "@components/PricingSection.astro";
import FoundingOffer from "@components/FoundingOffer.astro";
import FAQ from "@components/FAQ.astro";
import CTAFinal from "@components/CTAFinal.astro";
import WhatsAppButton from "@components/WhatsAppButton.astro";
import { offerComponents } from "@data/services";

const waNumber = import.meta.env.PUBLIC_WA_NUMBER;
const waMessage =
  "Hola%2C%20vi%20Agencia%20Chucao%20y%20me%20interesa%20el%20Lead%20Engine%20para%20mi%20cl%C3%ADnica%20dental.%20%C2%BFTienen%20disponibilidad%3F";
const waHref = `https://wa.me/${waNumber}?text=${waMessage}`;

const howSteps = [
  {
    number: "01",
    title: "Setup",
    timeline: "Días 1–7",
    description:
      "Configuramos tracking, creamos la landing de conversión por tratamiento y conectamos todos los canales. Al final de la semana, el sistema está instrumentado.",
  },
  {
    number: "02",
    title: "Tráfico",
    timeline: "Semana 2",
    description:
      "Activamos las campañas de Google Search. Capturamos demanda existente de pacientes buscando activamente tu tratamiento en Santiago.",
  },
  {
    number: "03",
    title: "Primeros leads",
    timeline: "Días 10–21",
    description:
      "Si hay demanda activa en tu zona y tratamiento, los primeros leads llegan en esta ventana. Activamos el protocolo de seguimiento por WhatsApp.",
  },
  {
    number: "04",
    title: "Medición y ajuste",
    timeline: "Día 30–45",
    description:
      "Primera revisión con datos reales: costo por lead, costo por evaluación, tasa de contacto. Ajustamos lo que muestre señales débiles.",
  },
];

const included = [
  "Google Search Ads (configuración, gestión y optimización)",
  "Landing de conversión por tratamiento",
  "Tracking completo GA4 + GTM",
  "Protocolo de seguimiento por WhatsApp",
  "SEO local + optimización de Google Business Profile",
  "Optimización de perfil en Doctoralia y directorios",
  "Remarketing mínimo (Meta como apoyo, no como canal principal)",
  "Reunión mensual de revisión",
  "Reporte mensual de CPL y costo por evaluación",
];

const excluded = [
  "Community management y gestión de redes sociales",
  "Producción de reels, videos o piezas creativas",
  "Desarrollo web completo o rediseño del sitio",
  "Branding e identidad visual",
  "Pauta publicitaria (va aparte, pagada por el cliente a Google)",
  "Calendario de contenidos y publicaciones periódicas",
  "Más de una reunión mensual incluida",
];

const extras = [
  "Nueva landing por tratamiento adicional",
  "Segunda sede",
  "Nueva categoría de tratamiento",
  "Integraciones técnicas adicionales",
  "Copy adicional",
  "Correcciones de sitio heredado fuera del embudo",
];

const faqItems = [
  {
    question: "¿Por qué CLP $1.000.000 si hay agencias más baratas?",
    answer:
      "Caro respecto de qué. Dos cierres de implante medio cubren el fee. Lo caro es seguir pagando clics sin saber cuántas evaluaciones reales salen de ahí. Una agencia a $300.000 que no puede mostrarte costo por evaluación no es más barata: es más opaca.",
  },
  {
    question: "Ya tenemos agencia.",
    answer:
      "La pregunta no es si tienen agencia. Es si hoy pueden mostrar costo por evaluación y costo por tratamiento cerrado, por canal. Si no lo tienen, están comprando actividad, no control. Esa es la diferencia.",
  },
  {
    question: "¿Cuánto demora en verse resultados?",
    answer:
      "Setup completo en 7–14 días. Primeros leads en 10–21 días si hay demanda activa en tu zona y tratamiento. Primeras conclusiones serias a los 30–45 días. Para juzgar sostenibilidad, necesitas 90 días de datos.",
  },
  {
    question: "¿Qué pasa si no funciona?",
    answer:
      "No hay permanencia larga. El setup cubre instrumentación y aprendizaje inicial. A los 45 días hacemos una revisión con datos reales: si hay fuga identificable, la corregimos. Si el mercado no tiene demanda activa suficiente, te lo decimos directamente.",
  },
  {
    question: "¿Qué no incluye el fee?",
    answer:
      "Community management, redes sociales, reels, desarrollo web, branding y pauta publicitaria. La pauta la paga el cliente directamente a Google. Tampoco incluimos más de una reunión mensual ni landings adicionales para nuevos tratamientos o sedes.",
  },
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Agencia Chucao",
  url: "https://agenciachucao.cl",
  telephone: "+56922218674",
  description:
    "Lead Engine para clínicas dentales de alto ticket en Santiago. Convertimos búsquedas activas en evaluaciones agendadas.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Santiago",
    addressRegion: "Región Metropolitana",
    addressCountry: "CL",
  },
  serviceType: ["Google Ads", "SEO Local", "Google Business Profile", "Lead Generation", "Conversión web"],
};
---

<BaseLayout
  title="Lead Engine para clínicas dentales en Santiago | Agencia Chucao"
  description="Convertimos búsquedas activas en evaluaciones agendadas. Sistema de captación medible para implantología, ortodoncia y rehabilitación en Santiago. Sin contratos largos."
  schema={localBusinessSchema}
>
  <Hero
    headline="Convierte búsquedas en evaluaciones agendadas."
    subheadline="Instalamos un sistema de captación medible para clínicas de implantología, ortodoncia y rehabilitación en Santiago. En 30 días tienes tres números visibles: costo por lead, costo por evaluación y costo por tratamiento."
    ctaText="Solicita tu auditoría gratuita"
    ctaHref="/contacto/"
  />

  <ProblemSection />

  <OfferSection components={offerComponents} />

  <HowItWorks steps={howSteps} />

  <IncludesExcludes included={included} excluded={excluded} extras={extras} />

  <PricingSection />

  <FoundingOffer spotsTotal={2} ctaHref="/contacto/" />

  <FAQ items={faqItems} />

  <CTAFinal
    headline="¿Tu clínica necesita un sistema de captación medible?"
    ctaText="Solicita tu auditoría gratuita"
    ctaHref="/contacto/"
    whatsappHref={waHref}
  />

  <WhatsAppButton />
</BaseLayout>
