---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import ProblemSection from "@components/ProblemSection.astro";
import OfferSection from "@components/OfferSection.astro";
import HowItWorks from "@components/HowItWorks.astro";
import ProofSection from "@components/ProofSection.astro";
import IncludesExcludes from "@components/IncludesExcludes.astro";
import PricingSection from "@components/PricingSection.astro";
import FoundingOffer from "@components/FoundingOffer.astro";
import FAQ from "@components/FAQ.astro";
import CTAFinal from "@components/CTAFinal.astro";
import WhatsAppButton from "@components/WhatsAppButton.astro";
import { offerComponents } from "@data/services";

const waNumber = import.meta.env.PUBLIC_WA_NUMBER;
const waMessage =
  "Hola%2C%20vi%20Agencia%20Chucao%20y%20me%20interesa%20el%20Lead%20Engine%20para%20mi%20cl%C3%ADnica%20dental.%20%C2%BFTienen%20disponibilidad%3F";
const waHref = `https://wa.me/${waNumber}?text=${waMessage}`;

const howSteps = [
  {
    number: "01",
    title: "Setup",
    timeline: "Días 1–7",
    description:
      "Instalamos el seguimiento de conversiones, creamos la landing por tratamiento y activamos todos los canales. Al final de la semana el sistema está listo.",
  },
  {
    number: "02",
    title: "Tráfico",
    timeline: "Semana 2",
    description:
      "Activamos las campañas de Google Search. Capturamos demanda existente de pacientes que buscan tu tratamiento en Santiago.",
  },
  {
    number: "03",
    title: "Primeros leads",
    timeline: "Días 10–21",
    description:
      "Si hay demanda activa en tu zona, los primeros leads llegan en esta ventana. Activamos el protocolo de seguimiento por WhatsApp.",
  },
  {
    number: "04",
    title: "Medición y ajustes",
    timeline: "Día 30–45",
    description:
      "Primera revisión con datos reales: gasto por evaluación, tasa de contacto, fuentes que funcionan. Ajustamos lo que muestre señales débiles.",
  },
];

const included = [
  "Setup inicial de Google Ads",
  "Landing de conversión",
  "Integración con WhatsApp",
  "Medición básica de conversiones",
  "SEO local básico / Google Business Profile",
  "Reporte mensual",
  "Ajustes mensuales de campaña",
];

const excluded = [
  "Community management diario",
  "Producción audiovisual",
  "Respuesta manual de WhatsApp por parte del equipo",
  "Garantía de cantidad exacta de pacientes",
  "Gestión clínica interna",
  "Software CRM avanzado",
];

const extras = [
  "Nueva landing por tratamiento adicional",
  "Segunda sede",
  "Nueva categoría de tratamiento",
  "Integraciones técnicas adicionales",
  "Copy adicional",
  "Correcciones de sitio heredado fuera del embudo",
];

const faqItems = [
  {
    question: "¿Por qué CLP $1.000.000 si hay agencias más baratas?",
    answer:
      "Depende de qué estás midiendo. Dos cierres de implante al mes ya cubren el fee. La pregunta más útil es cuánto te cuesta hoy conseguir cada paciente nuevo, contando todo: pauta, tiempo y esfuerzo. Si no tienes ese número, cualquier comparación de precios es arbitraria.",
  },
  {
    question: "Ya tenemos agencia.",
    answer:
      "Puede que funcione bien. Lo que vale la pena revisar es si hoy puedes ver cuánto te costó el último paciente de implante, desde que buscó en Google hasta que pagó. Si ese dato existe y es claro, probablemente no necesitas nada más. Si no está, hay algo concreto que se puede mejorar.",
  },
  {
    question: "¿Cuánto demora en verse resultados?",
    answer:
      "Setup completo en 7–14 días. Primeros leads en 10–21 días si hay demanda activa en tu zona y tratamiento. Primeras conclusiones serias a los 30–45 días. Para juzgar sostenibilidad, necesitas 90 días de datos.",
  },
  {
    question: "¿Qué pasa si no funciona?",
    answer:
      "No hay permanencia larga. El setup cubre la instalación y el aprendizaje inicial. A los 45 días revisamos con datos reales: si hay algo que optimizar, lo hacemos. Si hay razones estructurales por las que el canal no funciona para tu clínica o zona, te lo decimos con claridad.",
  },
  {
    question: "¿Qué no incluye el fee?",
    answer:
      "Community management, redes sociales, reels, desarrollo web, branding y pauta publicitaria. La pauta la paga el cliente directamente a Google. Tampoco incluimos más de una reunión mensual ni landings adicionales para nuevos tratamientos o sedes.",
  },
];

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Agencia Chucao",
  url: "https://agenciachucao.cl",
  telephone: "+56922218674",
  description:
    "Lead Engine para clínicas dentales de alto ticket en Santiago. Convertimos búsquedas activas en pacientes agendados.",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Santiago",
    addressRegion: "Región Metropolitana",
    addressCountry: "CL",
  },
  serviceType: ["Google Ads", "SEO Local", "Google Business Profile", "Lead Generation", "Conversión web"],
};
---

<BaseLayout
  title="Lead Engine para clínicas dentales en Santiago | Agencia Chucao"
  description="Convertimos búsquedas activas en pacientes agendados. Sistema de captación medible para implantología, ortodoncia y rehabilitación en Santiago. Sin contratos largos."
  schema={localBusinessSchema}
>
  <Hero
    headline="Convierte búsquedas en agendamientos."
    subheadline="Google Ads + landing de conversión + seguimiento por WhatsApp para clínicas dentales en Santiago. En 30 días sabes cuánto te cuesta cada paciente nuevo."
    ctaText="Solicita una revisión gratis"
    ctaHref="/contacto/"
  />

  <ProblemSection />

  <OfferSection components={offerComponents} />

  <HowItWorks steps={howSteps} />

  <ProofSection />

  <IncludesExcludes included={included} excluded={excluded} extras={extras} />

  <PricingSection />

  <FoundingOffer spotsTotal={2} ctaHref="/contacto/" />

  <FAQ items={faqItems} />

  <CTAFinal
    headline="Revisemos si tu clínica puede generar más agendamientos desde Google."
    ctaText="Solicita una revisión gratis"
    ctaHref="/contacto/"
    whatsappHref={waHref}
  />

  <WhatsAppButton />
</BaseLayout>
