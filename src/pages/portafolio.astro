---
import BaseLayout from '@layouts/BaseLayout.astro';
import PortfolioCard from '@components/PortfolioCard.astro';
import { portfolio } from '@data/portfolio';

// Real projects first, comingSoon at end
const sorted = [
  ...portfolio.filter((p) => !p.comingSoon),
  ...portfolio.filter((p) => p.comingSoon),
];
---

<BaseLayout
  title="Portafolio — Proyectos reales, resultados reales"
  description="Desarrollo web y SEO técnico para negocios chilenos. TRX Concept, Proyecto Matriz, Fiberpole, Invenio y más proyectos en camino."
>

  <header class="port-hero noise-bg">
    <div class="container port-hero-inner">
      <p class="section-label section-label-light hero-anim-1">Portafolio</p>
      <h1 class="port-h1 hero-anim-2">Proyectos reales, resultados reales</h1>
      <p class="port-lede hero-anim-3">
        No mostramos mockups. Mostramos proyectos entregados y funcionando para clientes reales.
      </p>
    </div>
  </header>

  <section class="section-py port-body">
    <div class="container">
      <div class="port-grid">
        {sorted.map((project) => (
          <div class="scroll-reveal">
            <PortfolioCard project={project} />
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .port-hero {
    background: var(--color-forest);
    color: var(--color-white);
    padding-block: clamp(4rem, 8vw, 6rem);
  }
  .port-hero-inner { max-width: 64ch; }
  .port-h1 {
    font-size: var(--text-h1-size);
    font-weight: var(--text-h1-weight);
    letter-spacing: var(--text-h1-track);
    line-height: var(--text-h1-leading);
    color: var(--color-white);
    margin-block: 1.25rem 1rem;
  }
  .port-lede {
    font-family: var(--font-serif);
    font-size: var(--text-lede-size);
    line-height: var(--text-lede-leading);
    color: rgba(255, 255, 255, 0.65);
    max-width: 52ch;
  }

  .port-body { background: var(--color-sage); }

  .port-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px)  { .port-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .port-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
